{
  "name": "DORIS",
  "type": "MIDDLEWARE",
  "label": "Doris",
  "description": "简单易用、高性能和统一的分析数据库",
  "version": "4.0.6",
  "sortNum": 11,
  "createDecompressDir": false,
  "dependencies": [],
  "arch": {
    "x86_64": {
      "packageName": "apache-doris-4.0.6-bin-x64.tar.gz",
      "decompressPackageName": "apache-doris-4.0.6"
    },
    "aarch64": {
      "packageName": "apache-doris-4.0.6-bin-arm64.tar.gz",
      "decompressPackageName": "apache-doris-4.0.6"
    }
  },
  "serviceHooks": [
    {
      "type": "POST_INSTALL",
      "action": "dorisRootPasswordInit",
      "params": {
        "maxAttempts": 24,
        "intervalMs": 5000
      }
    },
    {
      "type": "POST_INSTALL",
      "action": "otelSchemaInit",
      "params": {
        "maxAttempts": 24,
        "intervalMs": 5000
      }
    }
  ],
  "roles": [
    {
      "name": "DorisFE",
      "label": "DorisFE",
      "roleType": "master",
      "cardinality": "1+",
      "logFile": "fe/log/fe.log",
      "serverPorts": [],
      "jmxPortParam": "http_port",
      "runAs": {},
      "startRunner": {
        "timeout": "600",
        "program": "fe/bin/start_fe.sh",
        "args": [
          "--daemon"
        ]
      },
      "stopRunner": {
        "timeout": "600",
        "program": "fe/bin/stop_fe.sh",
        "args": [
          "--daemon"
        ]
      },
      "statusRunner": {
        "timeout": "60",
        "program": "fe/bin/status_fe.sh",
        "args": [
          "status",
          "fe"
        ]
      },
      "restartRunner": {
        "timeout": "60",
        "args": []
      },
      "externalLink": {
        "name": "FE UI",
        "label": "FE UI",
        "url": "http://${DORIS.DorisFE.__hostIp__}:${DORIS.http_port}"
      },
      "hooks": [
        {
          "type": "POST_INSTALL",
          "action": "download",
          "params": {
            "to": "fe/bin/status_fe.sh",
            "md5": "e16e258a2278e15c07db4b43e175ec15",
            "from": "script/status_fe.sh",
            "templateId": "2019333119884447746"
          }
        },
        {
          "type": "POST_INSTALL",
          "action": "append_line",
          "params": {
            "line": 2,
            "text": "export JAVA_HOME=$JAVA_HOME17",
            "source": "fe/bin/start_fe.sh"
          }
        }
      ]
    },
    {
      "name": "DorisBE",
      "label": "DorisBE",
      "roleType": "worker",
      "cardinality": "1+",
      "logFile": "be/log/be.INFO",
      "serverPorts": [],
      "jmxPortParam": "webserver_port",
      "runAs": {},
      "startRunner": {
        "timeout": "600",
        "program": "be/bin/start_be.sh",
        "args": [
          "--daemon"
        ]
      },
      "stopRunner": {
        "timeout": "600",
        "program": "be/bin/stop_be.sh",
        "args": [
          "--daemon"
        ]
      },
      "statusRunner": {
        "timeout": "60",
        "program": "be/bin/status_be.sh",
        "args": [
          "status",
          "be"
        ]
      },
      "restartRunner": {
        "timeout": "60",
        "args": []
      },
      "externalLink": {},
      "hooks": [
        {
          "type": "POST_INSTALL",
          "action": "download",
          "params": {
            "to": "be/bin/status_be.sh",
            "md5": "ad75f5dba8c99790396b5a52d3360932",
            "from": "script/status_be.sh",
            "templateId": "2019333287606276097"
          }
        },
        {
          "type": "POST_INSTALL",
          "action": "append_line",
          "params": {
            "line": 2,
            "text": "ulimit -c 0 -n 655350",
            "source": "be/bin/start_be.sh"
          }
        },
        {
          "type": "POST_INSTALL",
          "action": "append_line",
          "params": {
            "line": 2,
            "text": "export JAVA_HOME=$JAVA_HOME17",
            "source": "be/bin/start_be.sh"
          }
        }
      ]
    }
  ],
  "configWriter": {
    "generators": [
      {
        "filename": "be.conf",
        "configFormat": "properties",
        "outputDirectory": "be/conf",
        "templateType": "CUSTOM",
        "includeParams": [
          "be_priority_networks",
          "sys_log_level",
          "be_port",
          "webserver_port",
          "brpc_port",
          "storage_root_path",
          "mem_limit",
          "custom.be.conf"
        ]
      },
      {
        "filename": "fe.conf",
        "configFormat": "custom",
        "outputDirectory": "fe/conf",
        "templateType": "DEFAULT",
        "templateId": 2003733699520434177,
        "templateName": "doris_fe.ftl",
        "includeParams": [
          "fe_heap_size",
          "cluster_id",
          "meta_dir",
          "http_port",
          "rpc_port",
          "query_port",
          "fe_priority_networks",
          "lower_case_table_names",
          "enable_outfile_to_local",
          "custom.fe.conf"
        ]
      },
      {
        "filename": "fe.uni.conf",
        "configFormat": "properties",
        "outputDirectory": "fe/conf",
        "templateType": "CUSTOM",
        "includeParams": [
          "root_password"
        ]
      }
    ]
  },
  "parameters": [
    {
      "name": "cluster_id",
      "description": "相同集群ID的FE/BE节点属于同一个集群",
      "label": "集群ID",
      "hidden": false,
      "required": true,
      "type": "input",
      "defaultValue": "1",
      "configurableInWizard": true,
      "register": false
    },
    {
      "name": "meta_dir",
      "description": "FE元数据的保存目录",
      "label": "FE元数据的保存目录",
      "hidden": false,
      "required": true,
      "configType": "path",
      "type": "input",
      "defaultValue": "/data/doris/fe/doris-meta",
      "configurableInWizard": true,
      "register": false
    },
    {
      "name": "root_password",
      "description": "设置root用户初始化密码",
      "label": "设置root用户初始化密码",
      "hidden": false,
      "required": true,
      "type": "input",
      "defaultValue": "3ght%ed75BGk",
      "configurableInWizard": true,
      "register": true
    },
    {
      "name": "otel_collector_password",
      "description": "Doris otel_collector 账号(OTel Collector 写入用)的密码，留空则自动生成随机密码",
      "label": "OTel Collector 写入密码",
      "hidden": false,
      "required": false,
      "type": "password",
      "defaultValue": "",
      "configurableInWizard": true,
      "register": true
    },
    {
      "name": "otel_reader_password",
      "description": "Doris otel_reader 账号(平台查询 Doris 指标用)的密码，留空则自动生成随机密码",
      "label": "OTel Reader 查询密码",
      "hidden": false,
      "required": false,
      "type": "password",
      "defaultValue": "",
      "configurableInWizard": true,
      "register": true
    },
    {
      "name": "http_port",
      "key": "http_port",
      "description": "FE节点上前端界面的端口",
      "label": "FE节点上前端界面的端口",
      "hidden": false,
      "required": true,
      "type": "input",
      "defaultValue": "8030",
      "configurableInWizard": true,
      "register": true
    },
    {
      "name": "rpc_port",
      "key": "rpc_port",
      "description": "FE 节点上 Thrift 服务器的端口。",
      "label": "FE节点上Thrift服务器的端口",
      "hidden": false,
      "required": true,
      "type": "input",
      "defaultValue": "9020",
      "configurableInWizard": true,
      "register": false
    },
    {
      "name": "query_port",
      "key": "query_port",
      "description": "FE 节点上 MySQL 服务器的端口",
      "label": "FE节点上MySQL服务器的端口",
      "hidden": false,
      "required": true,
      "type": "input",
      "defaultValue": "9030",
      "configurableInWizard": true,
      "register": true
    },
    {
      "name": "fe_priority_networks",
      "description": "为那些有多个 IP 地址的服务器声明一个选择策略。\n请注意，最多应该有一个 IP 地址与此列表匹配。这是一个以分号分隔格式的列表，用 CIDR 表示法，例如 10.10.10.0/24。 如果没有匹配这条规则的ip，会随机选择一个。",
      "label": "FE优先网段",
      "hidden": false,
      "required": true,
      "type": "input",
      "defaultValue": "0.0.0.0/24",
      "configurableInWizard": true,
      "register": false
    },
    {
      "name": "fe_heap_size",
      "description": "FE最大堆内存，单位为GB",
      "label": "FE最大堆内存",
      "hidden": false,
      "required": true,
      "configType": "map",
      "type": "input",
      "defaultValue": "8",
      "configurableInWizard": true,
      "register": false
    },
    {
      "name": "lower_case_table_names",
      "description": "值为 0 时，表名大小写敏感。默认为0。\n值为 1 时，表名大小写不敏感，doris在存储和查询时会将表名转换为小写。\n优点是在一条语句中可以使用表名的任意大小写形式\n缺点是建表后无法获得建表语句中指定的表名，show tables 查看的表名为指定表名的小写。\n值为 2 时，表名大小写不敏感，doris存储建表语句中指定的表名，查询时转换为小写进行比较。\n优点是show tables 查看的表名为建表语句中指定的表名；\n缺点是同一语句中只能使用表名的一种大小写形式。",
      "label": "表名大小写是否敏感,只有初始化安装时有效",
      "hidden": false,
      "required": true,
      "type": "select",
      "defaultValue": "0",
      "selectValue": [
        "0",
        "1",
        "2"
      ],
      "configurableInWizard": true,
      "register": false
    },
    {
      "name": "enable_outfile_to_local",
      "description": "是否允许 outfile 函数将结果导出到本地磁盘",
      "label": "是否允许outfile函数将结果导出到本地磁盘",
      "hidden": false,
      "required": true,
      "type": "switch",
      "defaultValue": false,
      "configurableInWizard": true,
      "register": false
    },
    {
      "name": "be_priority_networks",
      "description": "为那些有多个 IP 地址的服务器声明一个选择策略。\n请注意，最多应该有一个 IP 地址与此列表匹配。这是一个以分号分隔格式的列表，用 CIDR 表示法，例如 10.10.10.0/24。 如果没有匹配这条规则的ip，会随机选择一个。",
      "label": "BE优先网段",
      "hidden": false,
      "required": true,
      "type": "input",
      "defaultValue": "0.0.0.0/24",
      "configurableInWizard": true,
      "register": false
    },
    {
      "name": "sys_log_level",
      "description": "",
      "label": "BE服务日志级别",
      "hidden": false,
      "required": true,
      "type": "select",
      "defaultValue": "INFO",
      "selectValue": [
        "INFO",
        "WARNING",
        "ERROR",
        "FATAL"
      ],
      "configurableInWizard": true,
      "register": false
    },
    {
      "name": "be_port",
      "key": "be_port",
      "description": "BE admin端口",
      "label": "BE admin端口",
      "hidden": false,
      "required": true,
      "type": "input",
      "defaultValue": "9060",
      "configurableInWizard": true,
      "register": false
    },
    {
      "name": "webserver_port",
      "description": "BE WebServer端口",
      "label": "BE WebServer端口",
      "hidden": false,
      "required": true,
      "type": "input",
      "defaultValue": "8040",
      "configurableInWizard": true,
      "register": false
    },
    {
      "name": "brpc_port",
      "description": "BE Rpc端口",
      "label": "BE Rpc端口",
      "hidden": false,
      "required": true,
      "type": "input",
      "defaultValue": "8060",
      "configurableInWizard": true,
      "register": false
    },
    {
      "name": "storage_root_path",
      "description": "BE数据存储目录，可配置多个，按分号分隔，例如/data1,medium:HDD;/data2,medium:SSD;/data3",
      "label": "BE数据存储目录",
      "hidden": false,
      "required": true,
      "separator": ";",
      "configType": "path",
      "type": "multiple",
      "defaultValue": [
        "/data/doris/be/storage"
      ],
      "configurableInWizard": true,
      "register": false
    },
    {
      "name": "mem_limit",
      "description": "限制BE进程使用服务器最大内存百分比。用于防止BE内存挤占太多的机器内存，该参数必须大于0，当百分大于100%之后，该值会默认为100%。",
      "label": "BE进程使用服务器最大内存百分比",
      "hidden": false,
      "required": true,
      "type": "input",
      "defaultValue": "100%",
      "configurableInWizard": true,
      "register": false
    },
    {
      "name": "custom.fe.conf",
      "description": "自定义配置",
      "label": "自定义配置fe.conf",
      "hidden": false,
      "required": false,
      "configType": "custom",
      "type": "multipleWithKey",
      "defaultValue": [],
      "configurableInWizard": true,
      "register": false
    },
    {
      "name": "custom.be.conf",
      "description": "自定义配置",
      "label": "自定义配置be.conf",
      "hidden": false,
      "required": false,
      "configType": "custom",
      "type": "multipleWithKey",
      "defaultValue": [],
      "configurableInWizard": true,
      "register": false
    }
  ]
}
