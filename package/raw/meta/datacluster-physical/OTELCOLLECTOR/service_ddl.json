{
  "name": "OTELCOLLECTOR",
  "label": "OpenTelemetry Collector",
  "description": "统一可观测采集器(metrics/logs/traces)",
  "version": "0.156.0",
  "sortNum": 18,
  "dependencies": [],
  "createDecompressDir": true,
  "arch": {
    "x86_64": {
      "packageName": "otelcol-contrib_0.156.0_linux_amd64.tar.gz",
      "decompressPackageName": "otelcol-contrib_0.156.0"
    },
    "aarch64": {
      "packageName": "otelcol-contrib_0.156.0_linux_arm64.tar.gz",
      "decompressPackageName": "otelcol-contrib_0.156.0"
    }
  },
  "roles": [
    {
      "name": "OtelCollector",
      "label": "OtelCollector",
      "roleType": "worker",
      "cardinality": "1+",
      "logFile": "logs/otelcol.out",
      "jmxPortParam": "otelSelfMetricsPort",
      "startRunner": {
        "timeout": "60",
        "program": "control.sh",
        "args": [
          "start"
        ]
      },
      "stopRunner": {
        "timeout": "600",
        "program": "control.sh",
        "args": [
          "stop"
        ]
      },
      "statusRunner": {
        "timeout": "60",
        "program": "control.sh",
        "args": [
          "status"
        ]
      },
      "restartRunner": {
        "timeout": "60",
        "program": "control.sh",
        "args": [
          "restart"
        ]
      },
      "hooks": [
        {
          "type": "POST_INSTALL",
          "action": "download",
          "params": {
            "from": "script/control.sh",
            "to": "control.sh",
            "md5": "8bdffc91b9c7d28dcee374c09c3138f0"
          }
        }
      ]
    }
  ],
  "configWriter": {
    "generators": [
      {
        "filename": "otelcol.yaml",
        "configFormat": "custom",
        "outputDirectory": "config",
        "templateName": "otelcol.ftl",
        "includeParams": [
          "s3Endpoint",
          "s3Bucket",
          "s3Prefix",
          "s3Region",
          "memLimitMiB",
          "batchSize",
          "queueStorageDir",
          "exporterMode",
          "dorisEndpoint",
          "dorisDatabase",
          "dorisUser",
          "nodeHostname",
          "rawYaml",
          "otelSelfMetricsPort"
        ]
      },
      {
        "filename": "otelcol.env",
        "configFormat": "custom",
        "outputDirectory": "config",
        "templateName": "otelcol-env.ftl",
        "includeParams": [
          "s3AccessKey",
          "s3SecretKey",
          "dorisUser",
          "dorisPassword"
        ]
      }
    ]
  },
  "parameters": [
    {
      "name": "otelSelfMetricsPort",
      "label": "Collector 自监控端口",
      "description": "OTel Collector 自身 Prometheus 指标暴露端口(内部自采集亦用此端口)",
      "required": true,
      "enabled": true,
      "configType": "map",
      "type": "input",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "8888"
    },
    {
      "name": "rawYaml",
      "label": "otelcol.yaml 覆盖内容",
      "description": "非空时完全替换基础参数生成的 otelcol.yaml",
      "required": false,
      "enabled": true,
      "configType": "map",
      "type": "textarea",
      "defaultValue": "",
      "configurableInWizard": false,
      "hidden": true
    },
    {
      "name": "nodeHostname",
      "label": "节点主机名",
      "description": "host_metrics 采集的 service.instance.id，安装后由控制面按节点刷新为真实 hostname",
      "required": false,
      "enabled": true,
      "configType": "map",
      "type": "input",
      "defaultValue": "${host}",
      "configurableInWizard": false,
      "hidden": true
    },
    {
      "name": "exporterMode",
      "label": "Exporter 模式",
      "required": true,
      "enabled": true,
      "configType": "map",
      "type": "select",
      "defaultValue": "s3",
      "selectValue": [
        "s3",
        "doris"
      ],
      "configurableInWizard": true,
      "hidden": false
    },
    {
      "name": "dorisEndpoint",
      "label": "Doris Stream Load 端点",
      "required": false,
      "enabled": true,
      "configType": "map",
      "type": "input",
      "defaultValue": "",
      "configurableInWizard": false,
      "hidden": true
    },
    {
      "name": "dorisDatabase",
      "label": "Doris 数据库",
      "required": true,
      "enabled": true,
      "configType": "map",
      "type": "input",
      "defaultValue": "otel",
      "configurableInWizard": false,
      "hidden": true
    },
    {
      "name": "dorisUser",
      "label": "Doris 写入用户",
      "required": false,
      "enabled": true,
      "configType": "map",
      "type": "input",
      "defaultValue": "otel_collector",
      "configurableInWizard": false,
      "hidden": true
    },
    {
      "name": "dorisPassword",
      "label": "Doris 写入密码",
      "required": false,
      "enabled": true,
      "configType": "map",
      "type": "input",
      "defaultValue": "",
      "configurableInWizard": false,
      "hidden": true
    },
    {
      "name": "s3Endpoint",
      "label": "S3 端点(Rustfs)",
      "required": true,
      "enabled": true,
      "configType": "map",
      "type": "input",
      "defaultValue": "http://${ROOT.Rustfs.__hostIp__}:${ROOT.Rustfs.__port__}",
      "configurableInWizard": true,
      "hidden": false
    },
    {
      "name": "s3Bucket",
      "label": "S3 Bucket",
      "required": true,
      "enabled": true,
      "configType": "map",
      "type": "input",
      "defaultValue": "otel-bootstrap",
      "configurableInWizard": true,
      "hidden": false
    },
    {
      "name": "s3Prefix",
      "label": "S3 前缀",
      "required": true,
      "enabled": true,
      "configType": "map",
      "type": "input",
      "defaultValue": "node",
      "configurableInWizard": false,
      "hidden": false
    },
    {
      "name": "s3Region",
      "label": "S3 Region",
      "required": true,
      "enabled": true,
      "configType": "map",
      "type": "input",
      "defaultValue": "us-east-1",
      "configurableInWizard": false,
      "hidden": true
    },
    {
      "name": "memLimitMiB",
      "label": "内存限制(MiB)",
      "required": true,
      "enabled": true,
      "configType": "map",
      "type": "input",
      "defaultValue": "512",
      "configurableInWizard": true,
      "hidden": false
    },
    {
      "name": "batchSize",
      "label": "批量大小",
      "required": true,
      "enabled": true,
      "configType": "map",
      "type": "input",
      "defaultValue": "8192",
      "configurableInWizard": true,
      "hidden": false
    },
    {
      "name": "queueStorageDir",
      "label": "持久化队列目录",
      "required": true,
      "enabled": true,
      "configType": "map",
      "type": "input",
      "defaultValue": "/data/otelcol/storage",
      "configurableInWizard": false,
      "hidden": false
    },
    {
      "name": "s3AccessKey",
      "label": "S3 Access Key",
      "required": true,
      "enabled": true,
      "configType": "map",
      "type": "input",
      "defaultValue": "${ROOT.Rustfs.access_key}",
      "configurableInWizard": false,
      "hidden": true
    },
    {
      "name": "s3SecretKey",
      "label": "S3 Secret Key",
      "required": true,
      "enabled": true,
      "configType": "map",
      "type": "input",
      "defaultValue": "${ROOT.Rustfs.secret_key}",
      "configurableInWizard": false,
      "hidden": true
    }
  ]
}
