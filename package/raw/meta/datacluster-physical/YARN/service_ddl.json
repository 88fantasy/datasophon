{
  "name": "YARN",
  "type": "MIDDLEWARE",
  "label": "YARN",
  "description": "分布式资源调度与管理平台",
  "version": "3.5.0",
  "sortNum": 33,
  "createDecompressDir": false,
  "dependencies": [
    "HDFS"
  ],
  "roles": [
    {
      "name": "ResourceManager",
      "label": "ResourceManager",
      "sortNum": 1,
      "roleType": "master",
      "cardinality": "1+",
      "logFile": "logs/hadoop-yarn-resourcemanager-${ROOT.VosManager.__host__}.log",
      "serverPorts": [],
      "jmxPort": 9323,
      "jmxPortParam": "rmJmxPort",
      "runAs": {
        "user": "yarn",
        "group": "hadoop"
      },
      "startRunner": {
        "timeout": "60",
        "program": "control_hadoop.sh",
        "args": [
          "start",
          "resourcemanager"
        ]
      },
      "stopRunner": {
        "timeout": "600",
        "program": "control_hadoop.sh",
        "args": [
          "stop",
          "resourcemanager"
        ]
      },
      "statusRunner": {
        "timeout": "60",
        "program": "control_hadoop.sh",
        "args": [
          "status",
          "resourcemanager"
        ]
      },
      "restartRunner": {
        "timeout": "60",
        "program": "control_hadoop.sh",
        "args": [
          "restart",
          "resourcemanager"
        ]
      },
      "externalLink": {
        "name": "ResourceManager UI",
        "label": "ResourceManager UI",
        "url": "http://${host}:8088/ui2"
      },
      "hooks": [
        {
          "type": "POST_INSTALL",
          "action": "download",
          "params": {
            "to": "etc/hadoop/fair-scheduler.xml",
            "md5": "df88de39a103546c7d9e9d05b443f093",
            "from": "etc/hadoop/fair-scheduler.xml",
            "templateId": "2028716252782186498"
          }
        },
        {
          "type": "POST_INSTALL",
          "action": "nexus",
          "params": {
            "to": "spark-3.4.2-yarn-shuffle.jar",
            "from": "spark-3.4.2-yarn-shuffle.jar"
          }
        },
        {
          "type": "POST_INSTALL",
          "action": "sh",
          "params": {
            "commands": [
              [
                "cp",
                "/data/datasophon/datasophon-init/packages/spark-3.4.2-yarn-shuffle.jar",
                "share/hadoop/yarn/lib/"
              ]
            ]
          }
        }
      ]
    },
    {
      "name": "NodeManager",
      "label": "NodeManager",
      "sortNum": 3,
      "roleType": "worker",
      "cardinality": "1+",
      "logFile": "logs/hadoop-yarn-nodemanager-${ROOT.VosManager.__host__}.log",
      "jmxPort": 9324,
      "jmxPortParam": "nmJmxPort",
      "runAs": {
        "user": "yarn",
        "group": "hadoop"
      },
      "startRunner": {
        "timeout": "60",
        "program": "control_hadoop.sh",
        "args": [
          "start",
          "nodemanager"
        ]
      },
      "stopRunner": {
        "timeout": "600",
        "program": "control_hadoop.sh",
        "args": [
          "stop",
          "nodemanager"
        ]
      },
      "statusRunner": {
        "timeout": "60",
        "program": "control_hadoop.sh",
        "args": [
          "status",
          "nodemanager"
        ]
      },
      "hooks": [
        {
          "type": "POST_INSTALL",
          "action": "download",
          "params": {
            "to": "etc/hadoop/fair-scheduler.xml",
            "md5": "df88de39a103546c7d9e9d05b443f093",
            "from": "etc/hadoop/fair-scheduler.xml",
            "templateId": "2028749055355863042"
          }
        },
        {
          "type": "POST_INSTALL",
          "action": "nexus",
          "params": {
            "to": "spark-3.4.2-yarn-shuffle.jar",
            "from": "spark-3.4.2-yarn-shuffle.jar"
          }
        },
        {
          "type": "POST_INSTALL",
          "action": "sh",
          "params": {
            "commands": [
              [
                "cp",
                "/data/datasophon/datasophon-init/packages/spark-3.4.2-yarn-shuffle.jar",
                "share/hadoop/yarn/lib/"
              ]
            ]
          }
        }
      ]
    },
    {
      "name": "HistoryServer",
      "label": "HistoryServer",
      "sortNum": 2,
      "roleType": "master",
      "cardinality": "1",
      "logFile": "logs/hadoop-mapred-historyserver-${ROOT.VosManager.__host__}.log",
      "jmxPort": 9325,
      "jmxPortParam": "historyServerJmxPort",
      "runAs": {
        "user": "mapred",
        "group": "hadoop"
      },
      "startRunner": {
        "timeout": "60",
        "program": "control_hadoop.sh",
        "args": [
          "start",
          "historyserver"
        ]
      },
      "stopRunner": {
        "timeout": "600",
        "program": "control_hadoop.sh",
        "args": [
          "stop",
          "historyserver"
        ]
      },
      "statusRunner": {
        "timeout": "60",
        "program": "control_hadoop.sh",
        "args": [
          "status",
          "historyserver"
        ]
      }
    },
    {
      "name": "YarnClient",
      "label": "YarnClient",
      "roleType": "client",
      "cardinality": "1+",
      "runAs": {
        "user": "yarn",
        "group": "hadoop"
      }
    }
  ],
  "configWriter": {
    "generators": [
      {
        "filename": "yarn-site.xml",
        "configFormat": "xml",
        "outputDirectory": "etc/hadoop/",
        "templateType": "DEFAULT",
        "includeParams": [
          "yarn.webapp.ui2.enable",
          "yarn.nodemanager.resource.cpu-vcores",
          "yarn.nodemanager.resource.memory-mb",
          "yarn.scheduler.minimum-allocation-mb",
          "yarn.scheduler.minimum-allocation-vcores",
          "yarn.scheduler.maximum-allocation-mb",
          "yarn.scheduler.maximum-allocation-vcores",
          "yarn.nodemanager.vmem-pmem-ratio",
          "yarn.nodemanager.aux-services",
          "yarn.nodemanager.aux-services.spark_shuffle.class",
          "yarn.log-aggregation-enable",
          "yarn.log.server.url",
          "yarn.log-aggregation.retain-seconds",
          "yarn.nodemanager.remote-app-log-dir",
          "yarn.nodemanager.remote-app-log-dir-suffix",
          "yarn.resourcemanager.scheduler.class",
          "yarn.scheduler.fair.allocation.file",
          "yarn.scheduler.fair.preemption",
          "yarn.resourcemanager.ha.enabled",
          "yarn.resourcemanager.cluster-id",
          "yarn.resourcemanager.ha.rm-ids",
          "yarn.resourcemanager.hostname.rm1",
          "yarn.resourcemanager.hostname.rm2",
          "yarn.resourcemanager.address.rm1",
          "yarn.resourcemanager.address.rm2",
          "yarn.resourcemanager.webapp.address.rm1",
          "yarn.resourcemanager.webapp.address.rm2",
          "yarn.resourcemanager.scheduler.address.rm1",
          "yarn.resourcemanager.scheduler.address.rm2",
          "yarn.resourcemanager.resource-tracker.address.rm1",
          "yarn.resourcemanager.resource-tracker.address.rm2",
          "yarn.resourcemanager.zk-address",
          "yarn.resourcemanager.recovery.enabled",
          "yarn.resourcemanager.store.class",
          "yarn.application.classpath",
          "yarn.nodemanager.local-dirs",
          "yarn.nodemanager.log-dirs",
          "yarn.nodemanager.address",
          "yarn.nodemanager.resource.count-logical-processors-as-cores",
          "yarn.nodemanager.resource.detect-hardware-capabilities",
          "yarn.nodemanager.resource.pcores-vcores-multiplier",
          "yarn.resourcemanager.am.max-attempts",
          "yarn.node-labels.enabled",
          "yarn.node-labels.fs-store.root-dir",
          "yarn.resourcemanager.principal",
          "yarn.resourcemanager.keytab",
          "yarn.nodemanager.principal",
          "yarn.nodemanager.keytab",
          "yarn.nodemanager.container-executor.class",
          "yarn.nodemanager.linux-container-executor.group",
          "yarn.nodemanager.linux-container-executor.path",
          "custom.yarn.site.xml"
        ]
      },
      {
        "filename": "mapred-site.xml",
        "configFormat": "xml",
        "outputDirectory": "etc/hadoop/",
        "templateType": "DEFAULT",
        "includeParams": [
          "mapreduce.jobhistory.keytab",
          "mapreduce.jobhistory.principal",
          "mapreduce.cluster.local.dir",
          "mapreduce.jobhistory.address",
          "mapreduce.jobhistory.webapp.address",
          "mapreduce.jobhistory.done-dir",
          "mapreduce.jobhistory.intermediate-done-dir",
          "custom.mapred.site.xml"
        ]
      },
      {
        "filename": "yarn-env.sh",
        "configFormat": "custom",
        "outputDirectory": "etc/hadoop/",
        "templateName": "yarn-env.ftl",
        "includeParams": [
          "hadoopHome",
          "rmJmxPort",
          "nmJmxPort",
          "historyServerJmxPort"
        ]
      }
    ]
  },
