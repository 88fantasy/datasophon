{
  "name": "NACOS",
  "label": "Nacos",
  "description": "服务注册发现、服务配置管理",
  "version": "3.2.2",
  "sortNum": 80,
  "dependencies": [],
  "roles": [
    {
      "name": "NacosServer",
      "label": "NacosServer",
      "roleType": "master",
      "cardinality": "1",
      "logFile": "logs/start.out",
      "jmxPortParam": "nacosServerPort",
      "startRunner": {
        "timeout": "60",
        "program": "bin/startup.sh",
        "args": [
          "-m",
          "standalone"
        ]
      },
      "stopRunner": {
        "timeout": "600",
        "program": "bin/shutdown.sh",
        "args": []
      },
      "statusRunner": {
        "timeout": "60",
        "program": "bin/control_nacos.sh",
        "args": [
          "status",
          "standalone"
        ]
      },
      "restartRunner": {
        "timeout": "60",
        "program": "bin/control_nacos.sh",
        "args": [
          "restart",
          "standalone"
        ]
      },
      "externalLink": {
        "name": "Nacos UI",
        "label": "Nacos UI",
        "url": "http://${host}:${NACOS.nacosConsolePort}/"
      },
      "hooks": [
        {
          "type": "POST_INSTALL",
          "action": "download",
          "params": {
            "from": "script/control_nacos.sh",
            "to": "bin/control_nacos.sh",
            "md5": "66eddd29b1f85d39fcfd98485f5bd9d1"
          }
        },
        {
          "type": "POST_INSTALL",
          "action": "append_line",
          "params": {
            "line": 2,
            "text": "export JAVA_HOME=$JAVA_HOME17",
            "source": "bin/startup.sh"
          }
        }
      ]
    }
  ],
  "configWriter": {
    "generators": [
      {
        "filename": "application.properties",
        "configFormat": "custom",
        "outputDirectory": "conf",
        "templateName": "nacos-standalone.ftl",
        "includeParams": [
          "nacosServerPort",
          "nacosConsolePort",
          "nacosDbUrl",
          "nacosDbUser",
          "nacosDbPwd",
          "nacosAuthEnabled",
          "nacosTokenSecretKey",
          "nacosWebUI",
          "nacosUsername",
          "nacosPassword"
        ]
      }
    ]
  },
  "parameters": [
    {
      "name": "nacosServerPort",
      "label": "端口",
      "description": "端口",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "8848",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "8848"
    },
    {
      "name": "nacosConsolePort",
      "label": "控制台端口",
      "description": "控制台端口",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "8080",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "8080",
      "register": true
    },
    {
      "name": "nacosDbUrl",
      "label": "第一个数据库的URL",
      "description": "第一个数据库的URL",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "jdbc:mysql://${ROOT.Mysql.mysqlHostPort}/nacos?characterEncoding=utf8&connectTimeout=1000&socketTimeout=3000&autoReconnect=true&useUnicode=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true"
    },
    {
      "name": "nacosDbUser",
      "label": "数据库用户名",
      "description": "数据库用户名",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "nacos"
    },
    {
      "name": "nacosDbPwd",
      "label": "数据库密码",
      "description": "数据库密码",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "fI5sQ4yQ4fP5"
    },
    {
      "name": "nacosAuthEnabled",
      "label": "是否启用认证",
      "description": "是否启用认证",
      "required": true,
      "configType": "map",
      "type": "switch",
      "value": true,
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": true
    },
    {
      "name": "nacosTokenSecretKey",
      "label": "密钥",
      "description": "密钥(Base64)",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "a73d81760ee6fe6a0c2482e0b79a409ce810ec969b6cf5e27bb81d822449b9ea",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "a73d81760ee6fe6a0c2482e0b79a409ce810ec969b6cf5e27bb81d822449b9ea"
    },
    {
      "name": "nacosWebUI",
      "label": "是否启用界面",
      "description": "是否启用界面",
      "required": true,
      "configType": "map",
      "type": "switch",
      "value": true,
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": true
    },
    {
      "name": "nacosUsername",
      "label": "登录用户",
      "description": "登录用户",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "nacos"
    },
    {
      "name": "nacosPassword",
      "label": "密码",
      "description": "登录密码",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "Td3DM4gAEebqkwrgJtcg",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "Td3DM4gAEebqkwrgJtcg"
    }
  ],
  "arch": {
    "common": {
      "packageName": "nacos-server-3.2.2.tar.gz",
      "decompressPackageName": "nacos"
    }
  }
}
