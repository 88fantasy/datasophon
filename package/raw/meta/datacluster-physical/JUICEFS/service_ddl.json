{
  "name": "JUICEFS",
  "label": "Juicefs",
  "description": "高性能、云原生分布式文件系统",
  "version": "1.3.1",
  "sortNum": 81,
  "dependencies": [
    "MINIO"
  ],
  "createDecompressDir": true,
  "arch": {
    "x86_64": {
      "packageName": "juicefs-1.3.1-linux-amd64.tar.gz",
      "decompressPackageName": "juicefs-1.3.1"
    },
    "aarch64": {
      "packageName": "juicefs-1.3.1-linux-arm64.tar.gz",
      "decompressPackageName": "juicefs-1.3.1"
    }
  },
  "roles": [
    {
      "name": "JuicefsMount",
      "label": "JuicefsMount",
      "roleType": "worker",
      "cardinality": "1+",
      "logFile": "logs/appweb",
      "jmxPortParam": "juicefsJmxPort",
      "startRunner": {
        "timeout": "60",
        "program": "bin/control_juicefs.sh",
        "args": [
          "start"
        ]
      },
      "stopRunner": {
        "timeout": "600",
        "program": "bin/control_juicefs.sh",
        "args": [
          "stop"
        ]
      },
      "statusRunner": {
        "timeout": "60",
        "program": "bin/control_juicefs.sh",
        "args": [
          "status"
        ]
      },
      "restartRunner": {
        "timeout": "60",
        "program": "bin/control_juicefs.sh",
        "args": [
          "restart"
        ]
      },
      "hooks": [
        {
          "type": "POST_INSTALL",
          "action": "download",
          "params": {
            "from": "script/juicefs-format-wrapper.sh",
            "to": "bin/juicefs-format-wrapper.sh",
            "md5": "42afbf46e9625051f4637074fb7298ce"
          }
        },
        {
          "type": "POST_INSTALL",
          "action": "execShell",
          "params": {
            "commands": [
              "${ROOT.JUICEFS.INSTALL_PATH}/bin/juicefs-format-wrapper.sh  --storage ${JUICEFS.juicefsStorage} --bucket ${JUICEFS.juicefsBucket}  --access-key ${JUICEFS.juicefsAccessKey}  --secret-key ${JUICEFS.juicefsSecretKey} --no-update '${JUICEFS.juicefsMeta}'  ${JUICEFS.juicefsFileSystemName}"
            ]
          }
        }
      ]
    }
  ],
  "configWriter": {
    "generators": [
      {
        "filename": "control_juicefs.sh",
        "configFormat": "custom",
        "outputDirectory": "bin",
        "templateName": "juicefs-env.ftl",
        "includeParams": [
          "juicefsMeta",
          "juicefsMounts",
          "juicefsJmxPort"
        ]
      }
    ]
  },
  "parameters": [
    {
      "name": "juicefsJmxPort",
      "label": "JuiceFS 监控端口",
      "description": "JuiceFS mount --metrics Prometheus 监听端口",
      "required": true,
      "configType": "map",
      "type": "input",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "9567"
    },
    {
      "name": "juicefsMeta",
      "label": "元数据地址",
      "description": "元数据地址",
      "required": true,
      "configType": "map",
      "type": "input",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "mysql://juicefs:juicefs@(${ROOT.Mysql.__hostIp__}:3306)/juicefs"
    },
    {
      "name": "juicefsMounts",
      "label": "挂载目录列表",
      "description": "挂载目录列表",
      "required": true,
      "type": "multipleWithMap",
      "configType": "map",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": [
        {
          "path": "/data/install_datasophon/juicefs/appweb",
          "log": "appweb"
        }
      ]
    },
    {
      "name": "juicefsStorage",
      "label": "文件存储类型",
      "description": "文件存储类型",
      "required": true,
      "type": "input",
      "configType": "map",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "s3"
    },
    {
      "name": "juicefsBucket",
      "label": "文件储存桶",
      "description": "文件储存桶",
      "required": true,
      "type": "input",
      "configType": "map",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "http://${ROOT.Rustfs.__hostIp__}:${ROOT.Rustfs.__port__}/appweb"
    },
    {
      "name": "juicefsAccessKey",
      "label": "文件储存用户",
      "description": "文件储存用户",
      "required": true,
      "type": "input",
      "configType": "map",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "${ROOT.Rustfs.access_key}"
    },
    {
      "name": "juicefsSecretKey",
      "label": "文件储存秘钥",
      "description": "文件储存秘钥",
      "required": true,
      "type": "input",
      "configType": "map",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "${ROOT.Rustfs.secret_key}"
    },
    {
      "name": "juicefsFileSystemName",
      "label": "创建文件系统名称",
      "description": "创建文件系统名称",
      "required": true,
      "type": "input",
      "configType": "map",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "appweb"
    }
  ]
}
