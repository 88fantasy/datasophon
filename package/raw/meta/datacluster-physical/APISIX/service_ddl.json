{
  "name": "APISIX",
  "label": "Apisix",
  "description": "高性能分布式Api网关",
  "version": "3.17.0",
  "sortNum": 89,
  "dependencies": [],
  "roles": [
    {
      "name": "Apisix",
      "label": "Apisix",
      "roleType": "master",
      "cardinality": "1+",
      "logFile": "/usr/local/apisix/logs/access.log",
      "jmxPortParam": "apisixPrometheusPort",
      "startRunner": {
        "timeout": "60",
        "program": "apisix",
        "args": [
          "start",
          "-c",
          "/usr/local/apisix/conf/config.yaml"
        ]
      },
      "stopRunner": {
        "timeout": "600",
        "program": "apisix",
        "args": [
          "stop"
        ]
      },
      "statusRunner": {
        "timeout": "60",
        "program": "control.sh",
        "args": [
          "status"
        ]
      },
      "restartRunner": {
        "timeout": "60",
        "program": "apisix",
        "args": [
          "restart",
          "-c",
          "/usr/local/apisix/conf/config.yaml"
        ]
      },
      "hooks": [
        {
          "type": "POST_INSTALL",
          "action": "download",
          "params": {
            "from": "script/control.sh",
            "to": "control.sh",
            "md5": "e00a98fede2df4441a650b83f6374468"
          }
        }
      ]
    }
  ],
  "configWriter": {
    "generators": [
      {
        "filename": "config.yaml",
        "configFormat": "custom",
        "outputDirectory": "/usr/local/apisix/conf",
        "templateName": "apisix-config.ftl",
        "includeParams": [
          "apisixPort",
          "apisixPrometheusAddr",
          "apisixPrometheusPort"
        ]
      },
      {
        "filename": "apisix.yaml",
        "configFormat": "custom",
        "outputDirectory": "/usr/local/apisix/conf",
        "templateName": "apisix-routes.ftl",
        "includeParams": [
          "apisixRouteUri",
          "apisixUpstreamHost",
          "apisixUpstreamPort"
        ]
      }
    ]
  },
  "parameters": [
    {
      "name": "apisixPort",
      "key": "apisixPort",
      "label": "网关端口",
      "description": "网关入口端口",
      "required": true,
      "type": "input",
      "configType": "map",
      "value": 9080,
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": 9080
    },
    {
      "name": "apisixRouteUri",
      "key": "apisixRouteUri",
      "label": "验收路由路径",
      "description": "APISIX Standalone 最小静态路由路径",
      "required": true,
      "type": "input",
      "configType": "map",
      "value": "/get",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "/get"
    },
    {
      "name": "apisixUpstreamHost",
      "key": "apisixUpstreamHost",
      "label": "验收上游主机",
      "description": "APISIX Standalone 最小静态路由的上游主机或 IP",
      "required": true,
      "type": "input",
      "configType": "map",
      "value": "127.0.0.1",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "127.0.0.1"
    },
    {
      "name": "apisixUpstreamPort",
      "key": "apisixUpstreamPort",
      "label": "验收上游端口",
      "description": "APISIX Standalone 最小静态路由的上游端口",
      "required": true,
      "type": "input",
      "configType": "map",
      "value": 8080,
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": 8080
    },
    {
      "name": "apisixPrometheusAddr",
      "key": "apisixPrometheusAddr",
      "label": "监控访问地址",
      "description": "",
      "required": true,
      "type": "input",
      "configType": "map",
      "value": "${ip}",
      "configurableInWizard": false,
      "hidden": false,
      "defaultValue": "${ip}"
    },
    {
      "name": "apisixPrometheusPort",
      "key": "apisixPrometheusPort",
      "label": "监控暴露端口",
      "description": "APISIX prometheus 插件指标暴露端口",
      "required": true,
      "type": "input",
      "configType": "map",
      "value": 9091,
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": 9091
    }
  ],
  "arch": {
    "common": {
      "packageName": "apache-apisix-3.17.0-src.tgz",
      "decompressPackageName": "apache-apisix-3.17.0"
    }
  }
}
