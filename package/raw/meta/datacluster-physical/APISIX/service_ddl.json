{
  "name": "APISIX",
  "type": "MIDDLEWARE",
  "label": "Apisix",
  "description": "高性能分布式Api网关",
  "version": "3.17.0",
  "sortNum": 89,
  "dependencies": [],
  "roles": [
    {
      "name": "Apisix",
      "label": "Apisix",
      "roleType": "master",
      "cardinality": "1+",
      "logFile": "/usr/local/apisix/logs/access.log",
      "jmxPortParam": "apisixPrometheusPort",
      "startRunner": {
        "timeout": "60",
        "program": "control.sh",
        "args": [
          "start"
        ]
      },
      "stopRunner": {
        "timeout": "600",
        "program": "control.sh",
        "args": [
          "stop"
        ]
      },
      "statusRunner": {
        "timeout": "60",
        "program": "control.sh",
        "args": [
          "status"
        ]
      },
      "restartRunner": {
        "timeout": "60",
        "program": "control.sh",
        "args": [
          "restart"
        ]
      },
      "hooks": [
        {
          "type": "POST_INSTALL",
          "action": "execShell",
          "params": {
            "commands": [
              "bash ${ROOT.APISIX.INSTALL_PATH}/scripts/install.sh"
            ]
          }
        },
        {
          "type": "POST_INSTALL",
          "action": "download",
          "params": {
            "from": "script/control.sh",
            "to": "control.sh",
            "md5": "c888e1e696d92c9b4118e1f5e1965073"
          }
        }
      ]
    }
  ],
  "configWriter": {
    "generators": [
      {
        "filename": "config.yaml",
        "configFormat": "custom",
        "outputDirectory": "/usr/local/apisix/conf",
        "templateName": "apisix-config.ftl",
        "includeParams": [
          "apisixPort",
          "apisixPrometheusAddr",
          "apisixPrometheusPort"
        ]
      },
      {
        "filename": "apisix.yaml",
        "configFormat": "custom",
        "outputDirectory": "/usr/local/apisix/conf",
        "templateName": "apisix-routes.ftl",
        "includeParams": [
          "apisixRouteUri",
          "apisixUpstreamHost",
          "apisixUpstreamPort"
        ]
      }
    ]
  },
  "parameters": [
    {
      "name": "apisixPort",
      "key": "apisixPort",
      "label": "网关端口",
      "description": "网关入口端口",
      "required": true,
      "type": "input",
      "configType": "map",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": 9080
    },
    {
      "name": "apisixRouteUri",
      "key": "apisixRouteUri",
      "label": "验收路由路径",
      "description": "APISIX Standalone 最小静态路由路径",
      "required": true,
      "type": "input",
      "configType": "map",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "/get"
    },
    {
      "name": "apisixUpstreamHost",
      "key": "apisixUpstreamHost",
      "label": "验收上游主机",
      "description": "APISIX Standalone 最小静态路由的上游主机或 IP",
      "required": true,
      "type": "input",
      "configType": "map",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "127.0.0.1"
    },
    {
      "name": "apisixUpstreamPort",
      "key": "apisixUpstreamPort",
      "label": "验收上游端口",
      "description": "APISIX Standalone 最小静态路由的上游端口",
      "required": true,
      "type": "input",
      "configType": "map",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": 8080
    },
    {
      "name": "apisixPrometheusAddr",
      "key": "apisixPrometheusAddr",
      "label": "监控访问地址",
      "description": "",
      "required": true,
      "type": "input",
      "configType": "map",
      "configurableInWizard": false,
      "hidden": false,
      "defaultValue": "${ip}"
    },
    {
      "name": "apisixPrometheusPort",
      "key": "apisixPrometheusPort",
      "label": "监控暴露端口",
      "description": "APISIX prometheus 插件指标暴露端口",
      "required": true,
      "type": "input",
      "configType": "map",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": 9091
    }
  ],
  "arch": {
    "common": {
      "packageName": "apisix-3.17.0-openEuler-22.03-LTS-SP3-x86_64-standalone-rpm.tar.gz",
      "decompressPackageName": "apisix-3.17.0-openEuler-22.03-LTS-SP3-x86_64-standalone-rpm"
    }
  }
}
