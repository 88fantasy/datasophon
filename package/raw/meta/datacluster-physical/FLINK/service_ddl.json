{
  "name": "FLINK",
  "type": "MIDDLEWARE",
  "label": "Flink",
  "description": "实时计算引擎",
  "version": "2.3.0",
  "sortNum": 14,
  "createDecompressDir": false,
  "dependencies": [
    "YARN"
  ],
  "roles": [
    {
      "name": "FlinkClient",
      "label": "FlinkClient",
      "roleType": "client",
      "cardinality": "1+",
      "logFile": "log/flink-hive-client-${host}.log",
      "serverPorts": [],
      "runAs": {
        "user": "hive",
        "group": "hadoop"
      },
      "startRunner": {
        "timeout": "60",
        "args": []
      },
      "stopRunner": {
        "timeout": "60",
        "args": []
      },
      "statusRunner": {
        "timeout": "60",
        "args": []
      },
      "restartRunner": {
        "timeout": "60",
        "args": []
      },
      "externalLink": {
        "url": ""
      },
      "hooks": [
        {
          "type": "POST_INSTALL",
          "action": "link",
          "params": {
            "source": "/data/install_datasophon/flink/opt/flink-s3-fs-hadoop-1.16.2.jar",
            "target": "plugins/s3-fs-hadoop/flink-s3-fs-hadoop-1.16.2.jar"
          }
        },
        {
          "type": "POST_INSTALL",
          "action": "append_line",
          "params": {
            "line": 19,
            "text": "export JAVA_HOME=$JAVA_HOME17",
            "source": "bin/config.sh"
          }
        },
        {
          "type": "POST_INSTALL",
          "action": "append_line",
          "params": {
            "line": 20,
            "text": "export HADOOP_CLASSPATH=`/data/install_datasophon/hadoop classpath`",
            "source": "bin/config.sh"
          }
        }
      ]
    },
    {
      "name": "FlinkHistory",
      "label": "FlinkHistory",
      "roleType": "worker",
      "cardinality": "1",
      "logFile": "log/flink-hive-historyserver-1-${host}.log",
      "serverPorts": [],
      "runAs": {
        "user": "hive",
        "group": "hadoop"
      },
      "startRunner": {
        "timeout": "60",
        "program": "control_history.sh",
        "args": [
          "start"
        ]
      },
      "stopRunner": {
        "timeout": "600",
        "program": "control_history.sh",
        "args": [
          "stop"
        ]
      },
      "statusRunner": {
        "timeout": "60",
        "program": "control_history.sh",
        "args": [
          "status"
        ]
      },
      "restartRunner": {
        "timeout": "60",
        "program": "control_history.sh",
        "args": [
          "restart"
        ]
      },
      "externalLink": {
        "name": "History UI",
        "label": "History UI",
        "url": "http://${host}:8082"
      },
      "hooks": [
        {
          "type": "POST_INSTALL",
          "action": "download",
          "params": {
            "to": "control_history.sh",
            "md5": "172259bf4c1fddf6a69135d799edb77f",
            "from": "script/control_history.sh",
            "templateId": "2026858332670971906"
          }
        },
        {
          "type": "POST_INSTALL",
          "action": "link",
          "params": {
            "source": "/data/install_datasophon/flink/opt/flink-s3-fs-hadoop-1.16.2.jar",
            "target": "plugins/s3-fs-hadoop/flink-s3-fs-hadoop-1.16.2.jar"
          }
        },
        {
          "type": "POST_INSTALL",
          "action": "append_line",
          "params": {
            "line": 19,
            "text": "export JAVA_HOME=$JAVA_HOME17",
            "source": "bin/config.sh"
          }
        },
        {
          "type": "POST_INSTALL",
          "action": "append_line",
          "params": {
            "line": 20,
            "text": "export HADOOP_CLASSPATH=`/data/install_datasophon/hadoop classpath`",
            "source": "bin/config.sh"
          }
        },
        {
          "type": "PRE_INSTALL",
          "action": "s3Sync",
          "params": {
            "bucket": "public",
            "endpoint": "http://${ROOT.Rustfs.__hostIp__}:${ROOT.Rustfs.__port__}/",
            "accessKey": "${ROOT.Rustfs.access_key}",
            "secretKey": "${ROOT.Rustfs.secret_key}",
            "resourcePath": "minio/"
          }
        }
      ]
    }
  ],
  "configWriter": {
    "generators": [
      {
        "filename": "flink-conf.yaml",
        "configFormat": "custom",
        "outputDirectory": "conf",
        "templateType": "DEFAULT",
        "templateId": 2003734318654230529,
        "templateName": "properties3.ftl",
        "includeParams": [
          "jobmanager.memory.process.size",
          "taskmanager.memory.process.size",
          "state.backend",
          "state.checkpoints.dir",
          "state.savepoints.dir",
          "state.backend.incremental",
          "jobmanager.archive.fs.dir",
          "historyserver.web.port",
          "historyserver.archive.fs.dir",
          "historyserver.web.tmpdir",
          "classloader.check-leaked-classloader",
          "fs.allowed-fallback-filesystems",
          "s3.access-key",
          "s3.secret-key",
          "s3.endpoint",
          "s3.path.style.access",
          "custom.flink.conf.yaml"
        ]
      }
    ]
  },
  "parameters": [
    {
      "name": "jobmanager.memory.process.size",
      "description": "",
      "label": "jobmanager进程内存大小",
      "hidden": false,
      "required": true,
      "type": "input",
      "defaultValue": "1600m",
      "configurableInWizard": true,
      "register": false
    },
    {
      "name": "taskmanager.memory.process.size",
      "description": "",
      "label": "taskmanager进程内存大小",
      "hidden": false,
      "required": true,
      "type": "input",
      "defaultValue": "1728m",
      "configurableInWizard": true,
      "register": false
    },
    {
      "name": "state.backend",
      "description": "",
      "label": "状态持久化",
      "hidden": false,
      "required": true,
      "type": "input",
      "defaultValue": "rocksdb",
      "configurableInWizard": true,
      "register": false
    },
    {
      "name": "state.checkpoints.dir",
      "description": "",
      "label": "状态检查点持久化目录",
      "hidden": false,
      "required": true,
      "type": "input",
      "defaultValue": "s3://public/capacity/basic/ustream/flink/checkpoints/",
      "configurableInWizard": true,
      "register": false
    },
    {
      "name": "state.savepoints.dir",
      "description": "",
      "label": "状态保存点持久化目录",
      "hidden": false,
      "required": true,
      "type": "input",
      "defaultValue": "s3://public/capacity/basic/ustream/flink/savepoints/",
      "configurableInWizard": true,
      "register": false
    },
    {
      "name": "state.backend.incremental",
      "description": "",
      "label": "开启增量快照",
      "hidden": false,
      "required": true,
      "type": "switch",
      "defaultValue": true,
      "configurableInWizard": true,
      "register": false
    },
    {
      "name": "jobmanager.archive.fs.dir",
      "description": "",
      "label": "作业存档目录",
      "hidden": false,
      "required": true,
      "type": "input",
      "defaultValue": "s3://public/capacity/basic/ustream/flink/completed-jobs/",
      "configurableInWizard": true,
      "register": false
    },
    {
      "name": "historyserver.web.port",
      "description": "",
      "label": "HistoryServer页面端口",
      "hidden": false,
      "required": true,
      "type": "input",
      "defaultValue": "8082",
      "configurableInWizard": true,
      "register": false
    },
    {
      "name": "historyserver.archive.fs.dir",
      "description": "",
      "label": "监视目录列表(以逗号分隔的)",
      "hidden": false,
      "required": true,
      "type": "input",
      "defaultValue": "s3://public/capacity/basic/ustream/flink/completed-jobs/",
      "configurableInWizard": true,
      "register": false
    },
    {
      "name": "historyserver.web.tmpdir",
      "description": "",
      "label": "HistoryServer临时目录",
      "hidden": false,
      "required": true,
      "type": "input",
      "defaultValue": "/tmp/flink-web-history",
      "configurableInWizard": true,
      "register": false
    },
    {
      "name": "classloader.check-leaked-classloader",
      "description": "禁用classloader.check",
      "label": "禁用classloader.check",
      "hidden": false,
      "required": true,
      "type": "switch",
      "defaultValue": false,
      "configurableInWizard": true,
      "register": false
    },
    {
      "name": "fs.allowed-fallback-filesystems",
      "description": "",
      "label": "保存点模式",
      "hidden": false,
      "required": true,
      "type": "input",
      "defaultValue": "s3",
      "configurableInWizard": true,
      "register": false
    },
    {
      "name": "s3.access-key",
      "description": "",
      "label": "S3帐号",
      "hidden": false,
      "required": true,
      "type": "input",
      "defaultValue": "${ROOT.Rustfs.access_key}",
      "configurableInWizard": true,
      "register": false
    },
    {
      "name": "s3.secret-key",
      "description": "",
      "label": "S3密钥",
      "hidden": false,
      "required": true,
      "type": "input",
      "defaultValue": "${ROOT.Rustfs.secret_key}",
      "configurableInWizard": true,
      "register": false
    },
    {
      "name": "s3.endpoint",
      "description": "",
      "label": "S3地址",
      "hidden": false,
      "required": true,
      "type": "input",
      "defaultValue": "http://${ROOT.Rustfs.__hostIp__}:${ROOT.Rustfs.__port__}",
      "configurableInWizard": true,
      "register": false
    },
    {
      "name": "s3.path.style.access",
      "description": "",
      "label": "启用路径样式",
      "hidden": false,
      "required": true,
      "type": "switch",
      "defaultValue": true,
      "configurableInWizard": true,
      "register": false
    },
    {
      "name": "custom.flink.conf.yaml",
      "description": "自定义配置",
      "label": "自定义配置flink-conf.yaml",
      "hidden": false,
      "required": false,
      "configType": "custom",
      "type": "multipleWithKey",
      "defaultValue": [],
      "configurableInWizard": true,
      "register": false
    }
  ],
  "arch": {
    "common": {
      "packageName": "flink-2.3.0-bin-scala_2.12.tgz",
      "decompressPackageName": "flink-2.3.0"
    }
  }
}
