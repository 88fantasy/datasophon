{
  "name": "VALKEY",
  "label": "Valkey",
  "description": "开源的高性能键值对存储系统(Redis 的 BSD-3 开源分叉)",
  "version": "8.1.7",
  "sortNum": 91,
  "dependencies": [],
  "arch": {
    "x86_64": {
      "packageName": "valkey-8.1.7-jammy-x86_64.tar.gz",
      "decompressPackageName": "valkey-8.1.7-jammy-x86_64"
    },
    "aarch64": {
      "packageName": "valkey-8.1.7-jammy-arm64.tar.gz",
      "decompressPackageName": "valkey-8.1.7-jammy-arm64"
    }
  },
  "roles": [
    {
      "name": "ValkeyMaster",
      "label": "ValkeyMaster",
      "roleType": "master",
      "cardinality": "1",
      "logFile": "logs/master.log",
      "startRunner": {
        "timeout": "60",
        "program": "control_valkey.sh",
        "args": [
          "start",
          "master"
        ]
      },
      "stopRunner": {
        "timeout": "600",
        "program": "control_valkey.sh",
        "args": [
          "stop",
          "master"
        ]
      },
      "statusRunner": {
        "timeout": "60",
        "program": "control_valkey.sh",
        "args": [
          "status",
          "master"
        ]
      },
      "hooks": []
    },
    {
      "name": "ValkeyExporter",
      "label": "ValkeyExporter",
      "roleType": "worker",
      "cardinality": "1",
      "logFile": "redis-exporter/logs/exporter.log",
      "jmxPortParam": "valkeyExporterPort",
      "sortNum": 2,
      "startRunner": {
        "timeout": "60",
        "program": "control_valkey.sh",
        "args": [
          "start",
          "exporter"
        ]
      },
      "stopRunner": {
        "timeout": "600",
        "program": "control_valkey.sh",
        "args": [
          "stop",
          "exporter"
        ]
      },
      "statusRunner": {
        "timeout": "60",
        "program": "control_valkey.sh",
        "args": [
          "status",
          "exporter"
        ]
      },
      "restartRunner": {
        "timeout": "60",
        "program": "control_valkey.sh",
        "args": [
          "restart",
          "exporter"
        ]
      },
      "hooks": []
    }
  ],
  "configWriter": {
    "generators": [
      {
        "filename": "master.conf",
        "configFormat": "custom",
        "outputDirectory": "conf",
        "templateName": "valkey-master.ftl",
        "includeParams": [
          "valkeyMasterPort",
          "valkeyDataDir",
          "valkeyDatabases",
          "valkeyPass",
          "valkeyMaxMemory",
          "valkeyMaxMemoryPolicy",
          "custom.master.conf"
        ]
      },
      {
        "filename": "control_valkey.sh",
        "configFormat": "custom",
        "outputDirectory": "",
        "templateName": "control_valkey.ftl",
        "includeParams": [
          "valkeyExporterPort"
        ]
      }
    ]
  },
  "parameters": [
    {
      "name": "valkeyMasterPort",
      "label": "master节点端口号",
      "description": "",
      "configType": "map",
      "required": true,
      "type": "input",
      "value": "7501",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "7501"
    },
    {
      "name": "valkeyDataDir",
      "label": "数据存储目录",
      "description": "数据持久化存储目录",
      "configType": "map",
      "required": true,
      "type": "input",
      "value": "/data/valkey",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "/data/valkey"
    },
    {
      "name": "valkeyPass",
      "label": "连接密码",
      "description": "连接密码",
      "configType": "map",
      "required": true,
      "type": "input",
      "value": "fX0GzFyWOK4LR^9K",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "fX0GzFyWOK4LR^9K"
    },
    {
      "name": "valkeyDatabases",
      "label": "数据库数量",
      "description": "设定数据库库的数量",
      "configType": "map",
      "required": true,
      "type": "slider",
      "minValue": 0,
      "maxValue": 32,
      "value": "16",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "16"
    },
    {
      "name": "valkeyMaxMemory",
      "label": "最大内存(bytes)",
      "description": "最大内存限制(按字节)",
      "configType": "map",
      "required": true,
      "type": "slider",
      "minValue": 0,
      "maxValue": 4294967296,
      "value": 0,
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": 0
    },
    {
      "name": "valkeyMaxMemoryPolicy",
      "label": "内存过期策略",
      "description": "内存过期策略",
      "configType": "map",
      "required": true,
      "type": "select",
      "value": "volatile-random",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "volatile-random",
      "selectValue": [
        "volatile-lru",
        "allkeys-lru",
        "volatile-random",
        "allkeys-random",
        "volatile-ttl",
        "noeviction"
      ]
    },
    {
      "name": "valkeyExporterPort",
      "label": "监控暴露端口",
      "description": "redis_exporter 指标暴露端口",
      "configType": "map",
      "required": true,
      "type": "input",
      "value": "9121",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "9121"
    },
    {
      "name": "custom.master.conf",
      "label": "自定义master配置",
      "description": "自定义master配置",
      "configType": "custom",
      "required": false,
      "type": "multipleWithKey",
      "value": [],
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": ""
    }
  ]
}
