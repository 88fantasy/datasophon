{
  "name": "PROMTAIL",
  "label": "Promtail",
  "description": "Loki日志收集客户端",
  "version": "2.8.11",
  "sortNum": 84,
  "dependencies": [
    "LOKI"
  ],
  "packageName": "promtail-linux-amd64.zip",
  "decompressPackageName": "promtail-2.8.11",
  "createDecompressDir": true,
  "arch": {
    "x86_64": {
      "packageName": "promtail-linux-amd64.zip"
    },
    "aarch64": {
      "packageName": "promtail-linux-arm64.zip"
    }
  },
  "roles": [
    {
      "name": "Promtail",
      "label": "Promtail",
      "roleType": "worker",
      "cardinality": "1",
      "logFile": "logs/promtail.out",
      "startRunner": {
        "timeout": "60",
        "program": "control.sh",
        "args": [
          "start"
        ]
      },
      "stopRunner": {
        "timeout": "600",
        "program": "control.sh",
        "args": [
          "stop"
        ]
      },
      "statusRunner": {
        "timeout": "60",
        "program": "control.sh",
        "args": [
          "status"
        ]
      },
      "restartRunner": {
        "timeout": "60",
        "program": "control.sh",
        "args": [
          "restart"
        ]
      },
      "hooks": [
        {
          "type": "POST_INSTALL",
          "action": "download",
          "params": {
            "from": "script/control.sh",
            "to": "control.sh",
            "md5": "2a55e9d99c1dfe4881f6666c21f49c5e"
          }
        }
      ]
    }
  ],
  "configWriter": {
    "generators": [
      {
        "filename": "config.yaml",
        "configFormat": "custom",
        "outputDirectory": "config",
        "templateName": "promtail.ftl",
        "includeParams": [
          "lokiUrl"
        ]
      }
    ]
  },
  "parameters": [
    {
      "name": "lokiUrl",
      "label": "Loki上报日志服务端口",
      "description": "若修改需要同步变更grafana数据源配置",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "http://localhost:3100/loki/api/v1/push",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "http://localhost:3100/loki/api/v1/push"
    }
  ]
}
