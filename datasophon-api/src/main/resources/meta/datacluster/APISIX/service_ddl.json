{
  "name": "APISIX",
  "label": "Apisix",
  "description": "高性能分布式Api网关",
  "version": "3.16.0",
  "sortNum": 89,
  "dependencies": [],
  "decompressPackageName": "apache-apisix-3.16.0",
  "roles": [
    {
      "name": "Apisix",
      "label": "Apisix",
      "roleType": "master",
      "cardinality": "1+",
      "logFile": "/usr/local/apisix/logs/access.log",
      "jmxPort": 9091,
      "startRunner": {
        "timeout": "60",
        "program": "apisix",
        "args": [
          "start",
          "-c",
          "/usr/local/apisix/conf/config.yaml"
        ]
      },
      "stopRunner": {
        "timeout": "600",
        "program": "apisix",
        "args": [
          "stop"
        ]
      },
      "statusRunner": {
        "timeout": "60",
        "program": "control.sh",
        "args": [
          "status"
        ]
      },
      "restartRunner": {
        "timeout": "60",
        "program": "apisix",
        "args": [
          "restart",
          "-c",
          "/usr/local/apisix/conf/config.yaml"
        ]
      },
      "hooks": [
        {
          "type": "POST_INSTALL",
          "action": "download",
          "params": {
            "from": "script/control.sh",
            "to": "control.sh",
            "md5": "e00a98fede2df4441a650b83f6374468"
          }
        }
      ]
    }
  ],
  "configWriter": {
    "generators": [
      {
        "filename": "apisix-config.yaml",
        "configFormat": "yaml",
        "outputDirectory": "conf",
        "includeParams": [
          "apisixPort",
          "apisixEtcdNodeList",
          "apisixAdminKey",
          "apisixAllowAdmin",
          "apisixPrometheusAddr"
        ]
      }
    ]
  },
  "parameters": [
    {
      "name": "apisixPort",
      "key": "apisix.node_listen",
      "label": "网关端口",
      "description": "网关入口端口",
      "required": true,
      "type": "input",
      "configType": "number",
      "value": 9080,
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": 9080
    },
    {
      "name": "apisixEtcdNodeList",
      "label": "ETCD",
      "key": "etcd.host",
      "description": "",
      "required": true,
      "type": "input",
      "configType": "stringArray",
      "value": "${etcd-advertise-client-urls}",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "${etcd-advertise-client-urls}"
    },
    {
      "name": "apisixAdminKey",
      "label": "管理密钥",
      "key": "apisix.admin_key",
      "description": "",
      "required": true,
      "type": "multipleWithMap",
      "value": [
        {
          "name": "admin",
          "key": "edd1c9f034335f136f87ad84b625c8f1",
          "role": "admin"
        }
      ],
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": [
        {
          "name": "admin",
          "key": "edd1c9f034335f136f87ad84b625c8f1",
          "role": "admin"
        }
      ]
    },
    {
      "name": "apisixAllowAdmin",
      "label": "允许访问",
      "key": "apisix.allow_admin",
      "description": "",
      "required": true,
      "type": "input",
      "configType": "stringArray",
      "value": [
        "0.0.0.0/0"
      ],
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": [
        "0.0.0.0/0"
      ]
    },
    {
      "name": "apisixPrometheusAddr",
      "label": "监控访问地址",
      "key": "plugin_attr.prometheus.export_addr.ip",
      "description": "",
      "required": true,
      "type": "input",
      "value": "${ip}",
      "configurableInWizard": false,
      "hidden": false,
      "defaultValue": "${ip}"
    }
  ],
  "arch": {
    "common": {
      "packageName": "apache-apisix-3.16.0-src.tgz"
    }
  }
}
