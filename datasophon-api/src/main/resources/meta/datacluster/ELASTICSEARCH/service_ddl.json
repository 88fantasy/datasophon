      "externalLink": {},
      "hooks": [
        {
          "type": "POST_INSTALL",
          "action": "download",
          "params": {
            "to": "elasticsearch-exporter/control_es_exporter.sh",
            "md5": "cab3260eed94bcc8d614def8123a1825",
            "from": "script/control_es_exporter.sh",
            "templateId": "2003758507066986497"
          }
        }
