{
  "name": "REDIS",
  "label": "Redis",
  "description": "开源的高性能键值对存储系统",
  "version": "8.6",
  "sortNum": 91,
  "dependencies": [],
  "decompressPackageName": "redis-8.6",
  "arch": {
    "x86_64": {
      "packageName": "redis-8.6.tar.gz"
    },
    "aarch64": {
      "packageName": "redis-8.6-arm.tar.gz"
    }
  },
  "roles": [
    {
      "name": "RedisMaster",
      "label": "RedisMaster",
      "roleType": "master",
      "cardinality": "1",
      "logFile": "logs/master.log",
      "startRunner": {
        "timeout": "60",
        "program": "control_redis.sh",
        "args": [
          "start",
          "master"
        ]
      },
      "stopRunner": {
        "timeout": "600",
        "program": "control_redis.sh",
        "args": [
          "stop",
          "master"
        ]
      },
      "statusRunner": {
        "timeout": "60",
        "program": "control_redis.sh",
        "args": [
          "status",
          "master"
        ]
      },
      "hooks": [
        {
          "type": "POST_INSTALL",
          "action": "download",
          "params": {
            "from": "script/control_redis.sh",
            "to": "control_redis.sh",
            "md5": "8b25b0fffa6034c219a68ec988daa0b8"
          }
        }
      ]
    },
    {
      "name": "RedisExporter",
      "label": "RedisExporter",
      "roleType": "worker",
      "cardinality": "1",
      "logFile": "redis-exporter/logs/exporter.log",
      "jmxPort": 9121,
      "sortNum": 2,
      "startRunner": {
        "timeout": "60",
        "program": "control_redis.sh",
        "args": [
          "start",
          "exporter"
        ]
      },
      "stopRunner": {
        "timeout": "600",
        "program": "control_redis.sh",
        "args": [
          "stop",
          "exporter"
        ]
      },
      "statusRunner": {
        "timeout": "60",
        "program": "control_redis.sh",
        "args": [
          "status",
          "exporter"
        ]
      },
      "restartRunner": {
        "timeout": "60",
        "program": "control_redis.sh",
        "args": [
          "restart",
          "exporter"
        ]
      },
      "hooks": [
        {
          "type": "POST_INSTALL",
          "action": "download",
          "params": {
            "from": "script/control_redis.sh",
            "to": "control_redis.sh",
            "md5": "8b25b0fffa6034c219a68ec988daa0b8"
          }
        }
      ]
    }
  ],
  "configWriter": {
    "generators": [
      {
        "filename": "master.conf",
        "configFormat": "custom",
        "outputDirectory": "conf",
        "templateName": "redis-master.ftl",
        "includeParams": [
          "redisMasterPort",
          "redisDataDir",
          "redisDatabases",
          "redisPass",
          "redisMaxMemory",
          "redisMaxMemoryPolicy",
          "custom.master.conf"
        ]
      }
    ]
  },
  "parameters": [
    {
      "name": "redisMasterPort",
      "label": "master节点端口号",
      "description": "",
      "configType": "map",
      "required": true,
      "type": "input",
      "value": "7501",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "7501"
    },
    {
      "name": "redisDataDir",
      "label": "数据存储目录",
      "description": "数据持久化存储目录",
      "configType": "map",
      "required": true,
      "type": "input",
      "value": "/data/redis",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "/data/redis"
    },
    {
      "name": "redisPass",
      "label": "连接密码",
      "description": "连接密码",
      "configType": "map",
      "required": true,
      "type": "input",
      "value": "fX0GzFyWOK4LR^9K",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "fX0GzFyWOK4LR^9K"
    },
    {
      "name": "redisDatabases",
      "label": "数据库数量",
      "description": "设定数据库库的数量",
      "configType": "map",
      "required": true,
      "type": "slider",
      "minValue": 0,
      "maxValue": 32,
      "value": "16",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "16"
    },
    {
      "name": "redisMaxMemory",
      "label": "最大内存(bytes)",
      "description": "最大内存限制(按字节)",
      "configType": "map",
      "required": true,
      "type": "slider",
      "minValue": 0,
      "maxValue": 4294967296,
      "value": 0,
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": 0
    },
    {
      "name": "redisMaxMemoryPolicy",
      "label": "内存过期策略",
      "description": "内存过期策略",
      "configType": "map",
      "required": true,
      "type": "select",
      "value": "volatile-random",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "volatile-random",
      "selectValue": [
        "volatile-lru",
        "allkeys-lru",
        "volatile-random",
        "allkeys-random",
        "volatile-ttl",
        "noeviction"
      ]
    },
    {
      "name": "custom.master.conf",
      "label": "自定义master配置",
      "description": "自定义master配置",
      "configType": "custom",
      "required": false,
      "type": "multipleWithKey",
      "value": [],
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": ""
    }
  ]
}
