{
  "name": "PORTAL",
  "label": "Portal",
  "description": "统一门户",
  "version": "3.1.0",
  "sortNum": 2,
  "dependencies": [
    "NACOS",
    "REDIS",
    "MINIO"
  ],
  "decompressPackageName": "portal-application-3.1.0-RELEASE",
  "roles": [
    {
      "name": "PortalAdmin",
      "label": "PortalAdmin",
      "roleType": "master",
      "cardinality": "1",
      "logFile": "logs/dgmed-framework-portal-server.log",
      "startRunner": {
        "timeout": "60",
        "program": "bin/server.sh",
        "args": [
          "start"
        ]
      },
      "stopRunner": {
        "timeout": "60",
        "program": "bin/server.sh",
        "args": [
          "stop"
        ]
      },
      "statusRunner": {
        "timeout": "60",
        "program": "bin/server.sh",
        "args": [
          "status"
        ]
      },
      "restartRunner": {
        "timeout": "60",
        "program": "bin/server.sh",
        "args": [
          "restart"
        ]
      },
      "hooks": [
        {
          "type": "POST_INSTALL",
          "action": "frontend",
          "params": {
            "meta": "${JUICEFS.juicefsMeta}",
            "source": "view/gateway-view",
            "target": "/gateway-view",
            "conf": "gateway-view.conf"
          }
        }
      ]
    }
  ],
  "configWriter": {
    "generators": [
      {
        "filename": ".user-java-opt.sh",
        "configFormat": "custom",
        "outputDirectory": "bin",
        "templateName": "user-java-opt.ftl",
        "includeParams": [
          "portalJasyptEncryptorPassword",
          "portalJavaMemoryOpt",
          "portalJdkHomePath"
        ]
      },
      {
        "filename": "bootstrap.yaml",
        "configFormat": "custom",
        "outputDirectory": "conf",
        "templateName": "portal-bootstrap.ftl",
        "includeParams": [
          "portalProfilesActive",
          "portalNacosHost",
          "portalNacosPort",
          "portalNacosUsername",
          "portalNacosPassword"
        ]
      },
      {
        "filename": "portal.yaml",
        "configFormat": "custom",
        "templateName": "portal.ftl",
        "outputDirectory": "${portalNacosUsername}:${portalNacosPassword}:${portalNacosHost}:${portalNacosPort}:${portalProfilesActive}:portal",
        "type": "nacos",
        "includeParams": [
          "portalProfilesActive",
          "portalNacosHost",
          "portalNacosPort",
          "portalNacosUsername",
          "portalNacosPassword"
        ]
      },
      {
        "filename": "common-redis.yaml",
        "configFormat": "custom",
        "templateName": "portal-common-redis.ftl",
        "outputDirectory": "${portalNacosUsername}:${portalNacosPassword}:${portalNacosHost}:${portalNacosPort}:${portalProfilesActive}:portal",
        "type": "nacos",
        "includeParams": [
          "portalProfilesActive",
          "portalNacosHost",
          "portalNacosPort",
          "portalNacosUsername",
          "portalNacosPassword"
        ]
      },
      {
        "filename": "common-mysql.yaml",
        "configFormat": "custom",
        "templateName": "portal-common-mysql.ftl",
        "outputDirectory": "${portalNacosUsername}:${portalNacosPassword}:${portalNacosHost}:${portalNacosPort}:${portalProfilesActive}:portal",
        "type": "nacos",
        "includeParams": [
          "portalProfilesActive",
          "portalNacosHost",
          "portalNacosPort",
          "portalNacosUsername",
          "portalNacosPassword"
        ]
      },
      {
        "filename": "common-log.yaml",
        "configFormat": "custom",
        "templateName": "portal-common-log.ftl",
        "outputDirectory": "${portalNacosUsername}:${portalNacosPassword}:${portalNacosHost}:${portalNacosPort}:${portalProfilesActive}:portal",
        "type": "nacos",
        "includeParams": [
          "portalProfilesActive",
          "portalNacosHost",
          "portalNacosPort",
          "portalNacosUsername",
          "portalNacosPassword"
        ]
      },
      {
        "filename": "gateway-mvc.yaml",
        "configFormat": "custom",
        "templateName": "portal-gateway-mvc.ftl",
        "outputDirectory": "${portalNacosUsername}:${portalNacosPassword}:${portalNacosHost}:${portalNacosPort}:${portalProfilesActive}:portal",
        "type": "nacos",
        "includeParams": [
          "portalProfilesActive",
          "portalNacosHost",
          "portalNacosPort",
          "portalNacosUsername",
          "portalNacosPassword"
        ]
      },
      {
        "filename": "common-oss.yaml",
        "configFormat": "custom",
        "templateName": "portal-common-oss.ftl",
        "outputDirectory": "${portalNacosUsername}:${portalNacosPassword}:${portalNacosHost}:${portalNacosPort}:${portalProfilesActive}:portal",
        "type": "nacos",
        "includeParams": [
          "portalProfilesActive",
          "portalNacosHost",
          "portalNacosPort",
          "portalNacosUsername",
          "portalNacosPassword"
        ]
      },
      {
        "filename": "portal-session.yaml",
        "configFormat": "custom",
        "templateName": "portal-session.ftl",
        "outputDirectory": "${portalNacosUsername}:${portalNacosPassword}:${portalNacosHost}:${portalNacosPort}:${portalProfilesActive}:portal",
        "type": "nacos",
        "includeParams": [
          "portalProfilesActive",
          "portalNacosHost",
          "portalNacosPort",
          "portalNacosUsername",
          "portalNacosPassword"
        ]
      },
      {
        "filename": "portal-proxy.yaml",
        "configFormat": "custom",
        "templateName": "portal-proxy.ftl",
        "outputDirectory": "${portalNacosUsername}:${portalNacosPassword}:${portalNacosHost}:${portalNacosPort}:${portalProfilesActive}:portal",
        "type": "nacos",
        "includeParams": [
          "portalProfilesActive",
          "portalNacosHost",
          "portalNacosPort",
          "portalNacosUsername",
          "portalNacosPassword",
          "portalProxy"
        ]
      },
      {
        "filename": "portal-vars.yaml",
        "configFormat": "custom",
        "templateName": "portal-vars.ftl",
        "outputDirectory": "${portalNacosUsername}:${portalNacosPassword}:${portalNacosHost}:${portalNacosPort}:${portalProfilesActive}:portal",
        "type": "nacos",
        "includeParams": [
          "portalProfilesActive",
          "portalNacosHost",
          "portalNacosPort",
          "portalNacosUsername",
          "portalNacosPassword",
          "portalRedisHost",
          "portalRedisPort",
          "portalRedisDb",
          "portalRedisPassword",
          "portalMysqlUrl",
          "portalMysqlUsername",
          "portalMysqlPassword",
          "portalLokiUrl",
          "portalDomain",
          "minioEndpoint",
          "minioAccessKey",
          "minioSecretKey",
          "minioBucket",
          "oidcSignKey"
        ]
      }
    ]
  },
  "parameters": [
    {
      "name": "portalJasyptEncryptorPassword",
      "label": "门户Jasypt密码",
      "description": "门户Jasypt密码",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "bs6xU7DDH#yrcxaetTTH5p^F$^=#5LG",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "bs6xU7DDH#yrcxaetTTH5p^F$^=#5LG"
    },
    {
      "name": "portalJavaMemoryOpt",
      "label": "jdk运行内存参数",
      "description": "eg:-Xms256M -Xmx1G -XX:MetaspaceSize=256M -XX:MaxMetaspaceSize=512M",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "-Xms256M -Xmx1G -XX:MetaspaceSize=256M -XX:MaxMetaspaceSize=512M",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "-Xms256M -Xmx1G -XX:MetaspaceSize=256M -XX:MaxMetaspaceSize=512M"
    },
    {
      "name": "portalJdkHomePath",
      "label": "门户jdk home路径",
      "description": "要求jdk17",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": ""
    },
    {
      "name": "portalProfilesActive",
      "label": "新门户启动profile",
      "description": "填dev或者prod",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "dev",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "prod"
    },
    {
      "name": "portalNacosHost",
      "label": "nacos host",
      "description": "nacos的host地址",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "${nacosHost}",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "${nacosHost}"
    },
    {
      "name": "portalNacosPort",
      "label": "nacos端口",
      "description": "nacos对外服务的端口",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "${nacosServerPort}",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "${nacosServerPort}"
    },
    {
      "name": "portalNacosUsername",
      "label": "nacos用户名",
      "description": "nacos用户名",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "${nacosUsername}",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "${nacosUsername}"
    },
    {
      "name": "portalNacosPassword",
      "label": "nacos密码",
      "description": "nacos密码",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "${nacosPassword}",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "${nacosPassword}"
    },
    {
      "name": "portalDomain",
      "label": "门户服务地址",
      "description": "对外服务地址(即前端的地址),只保留协议，host,端口。如http://192.168.2.130:19000",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": ""
    },
    {
      "name": "portalRedisHost",
      "label": "redis host",
      "description": "redis host",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "${redisHost}",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "${redisHost}"
    },
    {
      "name": "portalRedisPort",
      "label": "redis port",
      "description": "redis port",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "${redisMasterPort}",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "${redisMasterPort}"
    },
    {
      "name": "portalRedisPassword",
      "label": "redis password",
      "description": "redis password",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "${redisPass}",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "${redisPass}"
    },
    {
      "name": "portalRedisDb",
      "label": "redis db",
      "description": "redis db(1-16)",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "2"
    },
    {
      "name": "portalMysqlUrl",
      "label": "mysqlUrl",
      "description": "主机+冒号+端口",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "${apiHost}:3306"
    },
    {
      "name": "portalMysqlUsername",
      "label": "mysql username",
      "description": "数据库用户名",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "portal"
    },
    {
      "name": "portalMysqlPassword",
      "label": "mysql password",
      "description": "数据库密码",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "fI5sQ4yQ4fP5"
    },
    {
      "name": "portalLokiUrl",
      "label": "loki地址",
      "description": "loki地址,eg: http://192.168.2.122:3100",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "http://192.168.2.146:3100"
    },
    {
      "name": "minioEndpoint",
      "label": "minio地址",
      "description": "minio Endpoint，eg:http://192.168.2.130:9000/",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "http://192.168.2.146:9000/",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "http://192.168.2.146:9000/"
    },
    {
      "name": "minioAccessKey",
      "label": "minio access key",
      "description": "minio access key",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "${minioAccessKey}",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "${minioAccessKey}"
    },
    {
      "name": "minioSecretKey",
      "label": "minio secret key",
      "description": "minio secret key",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "${minioSecretKey}",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "${minioSecretKey}"
    },
    {
      "name": "minioBucket",
      "label": "minio桶",
      "description": "minio桶名，要求公共读，私有写",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "portal",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "portal"
    },
    {
      "name": "oidcSignKey",
      "label": "oidc协议签名key",
      "description": "oidc的签名密钥",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": null,
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "VG1GdFpTVXlNaVV6UVNVeU1pVkZOeVZDUWlVNVJpVkZOQ1ZDT0NVNE0="
    },
    {
      "name": "portalProxy",
      "label": "门户网络代理配置",
      "description": "门户网络代理配置,不需要代理填none, 网络代理详见文档",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "none"
    }
  ],
  "arch": {
    "common": {
      "packageName": "portal-application-3.1.0-RELEASE-install.tar.gz"
    }
  }
}
