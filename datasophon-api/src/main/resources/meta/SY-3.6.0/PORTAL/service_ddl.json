{
  "name": "PORTAL",
  "label": "Portal",
  "description": "统一门户",
  "version": "1.0.0",
  "sortNum": 2,
  "dependencies": [
    "NACOS",
    "REDIS",
    "MINIO"
  ],
  "packageName": "portal-application-1.0.0-RELEASE-install.tar.gz",
  "decompressPackageName": "portal-application-1.0.0-RELEASE",
  "roles": [
    {
      "name": "PortalAdmin",
      "label": "PortalAdmin",
      "roleType": "master",
      "cardinality": "1",
      "logFile": "logs/chinaunicom-medical-capacity-portal-server.log",
      "resourceStrategies": [
        {
          "type": "frontend",
          "meta": "${juicefsMeta}",
          "source": "view/gateway-view",
          "target": "/gateway-view",
          "conf": "gateway-view.conf"
        }
      ],
      "startRunner": {
        "timeout": "60",
        "program": "bin/server.sh",
        "args": [
          "start"
        ]
      },
      "stopRunner": {
        "timeout": "60",
        "program": "bin/server.sh",
        "args": [
          "stop"
        ]
      },
      "statusRunner": {
        "timeout": "60",
        "program": "bin/server.sh",
        "args": [
          "status"
        ]
      },
      "restartRunner": {
        "timeout": "60",
        "program": "bin/server.sh",
        "args": [
          "restart"
        ]
      }
    }
  ],
  "configWriter": {
    "generators": [
      {
        "filename": ".user-java-opt.sh",
        "configFormat": "custom",
        "outputDirectory": "bin",
        "templateName": "user-java-opt.ftl",
        "includeParams": [
          "portalJasyptEncryptorPassword",
          "portalJavaMemoryOpt",
          "portalJdkHomePath"
        ]
      },
      {
        "filename": "bootstrap.yaml",
        "configFormat": "custom",
        "outputDirectory": "conf",
        "templateName": "portal-bootstrap.ftl",
        "includeParams": [
          "portalRunInProd",
          "portalProfilesActive",
          "portalNacosHost",
          "portalNacosPort",
          "portalNacosUsername",
          "portalNacosPassword",
          "portalDomain",
          "dingdingProxyHost",
          "dingdingProxyPort",
          "minioOutsideUrl"
        ]
      },
      {
        "filename": "portal.yaml",
        "configFormat": "custom",
        "templateName": "portal.ftl",
        "outputDirectory": "${portalNacosUsername}:${portalNacosPassword}:${portalNacosHost}:${portalNacosPort}:${portalProfilesActive}:${portalAppNacosGroup}",
        "type": "nacos",
        "includeParams": [
          "portalProfilesActive",
          "portalNacosHost",
          "portalNacosPort",
          "portalNacosUsername",
          "portalNacosPassword",
          "portalAppNacosGroup"
        ]
      },
      {
        "filename": "common-redis.yaml",
        "configFormat": "custom",
        "templateName": "portal-common-redis.ftl",
        "outputDirectory": "${portalNacosUsername}:${portalNacosPassword}:${portalNacosHost}:${portalNacosPort}:${portalProfilesActive}:${portalAppNacosGroup}",
        "type": "nacos",
        "includeParams": [
          "portalProfilesActive",
          "portalNacosHost",
          "portalNacosPort",
          "portalNacosUsername",
          "portalNacosPassword",
          "portalAppNacosGroup"
        ]
      },
      {
        "filename": "common-mysql.yaml",
        "configFormat": "custom",
        "templateName": "portal-common-mysql.ftl",
        "outputDirectory": "${portalNacosUsername}:${portalNacosPassword}:${portalNacosHost}:${portalNacosPort}:${portalProfilesActive}:${portalAppNacosGroup}",
        "type": "nacos",
        "includeParams": [
          "portalProfilesActive",
          "portalNacosHost",
          "portalNacosPort",
          "portalNacosUsername",
          "portalNacosPassword",
          "portalAppNacosGroup"
        ]
      },
      {
        "filename": "common-log.yaml",
        "configFormat": "custom",
        "templateName": "portal-common-log.ftl",
        "outputDirectory": "${portalNacosUsername}:${portalNacosPassword}:${portalNacosHost}:${portalNacosPort}:${portalProfilesActive}:${portalAppNacosGroup}",
        "type": "nacos",
        "includeParams": [
          "portalProfilesActive",
          "portalNacosHost",
          "portalNacosPort",
          "portalNacosUsername",
          "portalNacosPassword",
          "portalAppNacosGroup"
        ]
      },
      {
        "filename": "gateway-mvc.yaml",
        "configFormat": "custom",
        "templateName": "portal-gateway-mvc.ftl",
        "outputDirectory": "${portalNacosUsername}:${portalNacosPassword}:${portalNacosHost}:${portalNacosPort}:${portalProfilesActive}:${portalAppNacosGroup}",
        "type": "nacos",
        "includeParams": [
          "portalProfilesActive",
          "portalNacosHost",
          "portalNacosPort",
          "portalNacosUsername",
          "portalNacosPassword",
          "portalAppNacosGroup",
          "portalRoutes"
        ]
      },
      {
        "filename": "common-oss.yaml",
        "configFormat": "custom",
        "templateName": "portal-common-oss.ftl",
        "outputDirectory": "${portalNacosUsername}:${portalNacosPassword}:${portalNacosHost}:${portalNacosPort}:${portalProfilesActive}:${portalAppNacosGroup}",
        "type": "nacos",
        "includeParams": [
          "portalProfilesActive",
          "portalNacosHost",
          "portalNacosPort",
          "portalNacosUsername",
          "portalNacosPassword",
          "portalAppNacosGroup"
        ]
      },
      {
        "filename": "portal-session.yaml",
        "configFormat": "custom",
        "templateName": "portal-session.ftl",
        "outputDirectory": "${portalNacosUsername}:${portalNacosPassword}:${portalNacosHost}:${portalNacosPort}:${portalProfilesActive}:${portalAppNacosGroup}",
        "type": "nacos",
        "includeParams": [
          "portalProfilesActive",
          "portalNacosHost",
          "portalNacosPort",
          "portalNacosUsername",
          "portalNacosPassword",
          "portalAppNacosGroup"
        ]
      },
      {
        "filename": "common-vars.yaml",
        "configFormat": "custom",
        "templateName": "portal-common-vars.ftl",
        "outputDirectory": "${portalNacosUsername}:${portalNacosPassword}:${portalNacosHost}:${portalNacosPort}:${portalProfilesActive}:${portalAppNacosGroup}",
        "type": "nacos",
        "includeParams": [
          "portalProfilesActive",
          "portalNacosHost",
          "portalNacosPort",
          "portalNacosUsername",
          "portalNacosPassword",
          "portalAppNacosGroup",
          "portalRedisHost",
          "portalRedisPort",
          "portalRedisDb",
          "portalRedisPassword",
          "portalLokiUrl",
          "minioEndpoint",
          "minioAccessKey",
          "minioSecretKey",
          "minioBucket"
        ]
      }
    ]
  },
  "parameters": [
    {
      "name": "portalJasyptEncryptorPassword",
      "label": "门户Jasypt密码",
      "description": "门户Jasypt密码",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": ""
    },
    {
      "name": "portalJavaMemoryOpt",
      "label": "jdk运行内存参数",
      "description": "eg:-Xms256M -Xmx1G -XX:MetaspaceSize=256M -XX:MaxMetaspaceSize=512M",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": ""
    },
    {
      "name": "portalJdkHomePath",
      "label": "门户jdk home路径",
      "description": "要求jdk17",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": ""
    },
    {
      "name": "portalRunInProd",
      "label": "是否运行在生产环境",
      "description": "如果是，则会关闭swagger相关功能",
      "required": true,
      "configType": "map",
      "type": "switch",
      "value": true,
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": true
    },
    {
      "name": "portalProfilesActive",
      "label": "新门户启动profile",
      "description": "填dev或者prod",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "dev",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "dev"
    },
    {
      "name": "portalNacosHost",
      "label": "nacos host",
      "description": "nacos的host地址",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "${nacosHost}",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "${nacosHost}"
    },
    {
      "name": "portalNacosPort",
      "label": "nacos端口",
      "description": "nacos对外服务的端口",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "${nacosServerPort}",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "${nacosServerPort}"
    },
    {
      "name": "portalNacosUsername",
      "label": "nacos用户名",
      "description": "nacos用户名",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "${nacosUsername}",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "${nacosUsername}"
    },
    {
      "name": "portalNacosPassword",
      "label": "nacos密码",
      "description": "nacos密码",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "${nacosPassword}",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "${nacosPassword}"
    },
    {
      "name": "portalAppNacosGroup",
      "label": "nacos配置的group",
      "description": "配置需要写到哪一个组(group)",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "portal",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "portal"
    },
    {
      "name": "portalDomain",
      "label": "门户服务地址",
      "description": "对外服务地址(即前端的地址),只保留协议，host,端口。如http://192.168.2.130:19000",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": ""
    },
    {
      "name": "dingdingProxyHost",
      "label": "钉钉API代理地址host",
      "description": "钉钉API代理地址host,如果无需代理，则为空",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": ""
    },
    {
      "name": "dingdingProxyPort",
      "label": "钉钉API代理地址port",
      "description": "钉钉API代理地址port,如果无需代理，则为空",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": ""
    },
    {
      "name": "portalRoutes",
      "label": "gateway转发路由",
      "description": "gateway转发路由配置",
      "required": true,
      "type": "multipleWithMap",
      "configType": "map",
      "value": [
        {
          "id": "portal",
          "uri": "lb://portal",
          "predicateUrl": "/gateway/portal/**",
          "rewriteReg": "/gateway/portal/(?<segment>.*)",
          "replaceReg": "/$\\{segment}"
        }
      ],
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": [
        {
          "id": "portal",
          "uri": "lb://portal",
          "predicateUrl": "/gateway/portal/**",
          "rewriteReg": "/gateway/portal/(?<segment>.*)",
          "replaceReg": "/$\\{segment}"
        }
      ]
    },
    {
      "name": "portalRedisHost",
      "label": "redis host",
      "description": "redis host",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "${redisHost}",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "${redisHost}"
    },
    {
      "name": "portalRedisPort",
      "label": "redis port",
      "description": "redis port",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "${redisMasterPort}",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "${redisMasterPort}"
    },{
      "name": "portalRedisPassword",
      "label": "redis password",
      "description": "redis password",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "${redisPass}",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "${redisPass}"
    },
    {
      "name": "portalRedisDb",
      "label": "redis db",
      "description": "redis db(1-16)",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "2"
    },
    {
      "name": "portalLokiUrl",
      "label": "loki地址",
      "description": "loki地址,eg: http://192.168.2.122:3100",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "http://192.168.2.146:3100"
    },
    {
      "name": "minioEndpoint",
      "label": "minio地址",
      "description": "minio Endpoint，eg:http://192.168.2.130:9000/",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "http://192.168.2.146:9000/",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "http://192.168.2.146:9000/"
    },
    {
      "name": "minioAccessKey",
      "label": "minio access key",
      "description": "minio access key",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "${minioAccessKey}",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "${minioAccessKey}"
    },
    {
      "name": "minioSecretKey",
      "label": "minio secret key",
      "description": "minio secret key",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "${minioSecretKey}",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "${minioSecretKey}"
    },
    {
      "name": "minioBucket",
      "label": "minio桶名",
      "description": "minio 桶名",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "portal",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "portal"
    },
    {
      "name": "minioOutsideUrl",
      "label": "minio外链地址",
      "description": "minio外链地址",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "/mfts/",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "/mfts/"
    }
  ]
}