{
	"name": "AMORO",
	"label": "Amoro",
	"description": "iceberg优化器",
	"version": "0.6.1",
	"sortNum": 92,
	"dependencies": [],
	"packageName": "amoro-0.6.1.tar.gz",
	"decompressPackageName": "amoro-0.6.1",
	"roles": [{
			"name": "AmoroServer",
			"label": "AmoroServer",
			"roleType": "master",
			"cardinality": "1",
			"logFile": "logs/ams-info.log",
			"startRunner": {
				"timeout": "60",
				"program": "bin/ams.sh",
				"args": ["start"]
			},
			"stopRunner": {
				"timeout": "60",
				"program": "bin/ams.sh",
				"args": ["stop"]
			},
			"statusRunner": {
				"timeout": "60",
				"program": "bin/ams.sh",
				"args": ["status"]
			},
			"restartRunner": {
				"timeout": "60",
				"program": "bin/ams.sh",
				"args": ["restart"]
			},
			"externalLink": {
				"name": "Amoro UI",
				"label": "Amoro UI",
				"url": "http://${host}:${amoroHttpPort}"
			}
		}
	],
	"configWriter": {
		"generators": [{
				"filename": "config.yaml",
				"configFormat": "custom",
				"outputDirectory": "conf/",
				"templateName": "amoro-config-yaml.ftl",
				"includeParams": [
						"amoroUsername",
						"amoroPassword",
						"amoroHttpPort",
						"amoroDbUrl",
						"amoroDbUsername",
						"amoroDbPassword",
						"amoroHaEnabled",
						"amoroHaZookeeperAddress",
						"javaHome",
						"amoroHadoopUsername",
						"amoroTerminalBackend",
						"amoroTerminalJdbcUrl",
						"amoroTerminalJdbcUser",
						"amoroTerminalJdbcPassword",
						"custom.terminal"
					]
				},
				{
					"filename": "jvm.properties",
					"configFormat": "properties",
					"outputDirectory": "conf/",
					"includeParams": [
						"xms",
						"xmx",
						"jmx.remote.port"
					]
				}
		]
	},
	"parameters": [
		{
			"name": "amoroUsername",
			"label": "登录用户",
			"description": "",
			"configType": "map",
			"required": true,
			"type": "input",
			"value": "",
			"configurableInWizard": true,
			"hidden": false,
			"defaultValue": "admin"
		},
		{
			"name": "amoroPassword",
			"label": "登录密码",
			"description": "",
			"configType": "map",
			"required": true,
			"type": "input",
			"value": "",
			"configurableInWizard": true,
			"hidden": false,
			"defaultValue": "ydafa@dfdaOP"
		},
		{
			"name": "amoroHttpPort",
			"label": "amoro登录端口",
			"description": "",
			"configType": "map",
			"required": true,
			"type": "input",
			"value": "",
			"configurableInWizard": true,
			"hidden": false,
			"defaultValue": "1630"
		},
		{
			"name": "amoroDbUrl",
			"label": "数据源URL",
