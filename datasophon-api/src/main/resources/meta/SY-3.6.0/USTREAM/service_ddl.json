			"required": true,
			"type": "input",
			"value": "",
			"configurableInWizard": true,
			"hidden": false,
			"defaultValue": "${USTREAM_HOME}"
		},
		{
			"name": "ustreamExecutorPath",
			"label": "ustream执行器路径",
