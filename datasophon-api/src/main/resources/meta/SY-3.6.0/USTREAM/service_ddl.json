{
	"name": "USTREAM",
	"label": "Ustream",
	"description": "数衍实时组件",
	"version": "3.2.3",
	"sortNum": 78,
	"dependencies": ["FLINK"],
	"packageName": "ustream-3.2.3-SNAPSHOT-bin.tar.gz",
	"decompressPackageName": "ustream-3.2.3-SNAPSHOT",
	"roles": [{
			"name": "UstreamServer",
			"label": "UstreamServer",
			"roleType": "master",
			"runAs": {
				"user": "hive",
				"group": "hadoop"
			},
			"cardinality": "1",
			"logFile": "logs/ustream.log",
			"jmxPort": 9112,
			"startRunner": {
				"timeout": "60",
				"program": "bin/ustream-daemon.sh",
				"args": ["start", "server"]
			},
			"stopRunner": {
				"timeout": "600",
				"program": "bin/ustream-daemon.sh",
				"args": ["stop", "server"]
			},
			"statusRunner": {
				"timeout": "60",
				"program": "bin/ustream-daemon.sh",
				"args": ["status", "server"]
			},
			"restartRunner": {
				"timeout": "60",
				"program": "bin/ustream-daemon.sh",
				"args": ["restart", "server"]
			}
		}
	],
	"configWriter": {
		"generators": [{
				"filename": "application.yaml",
				"configFormat": "custom",
				"outputDirectory": "conf/",
				"templateName": "ustream-yaml.ftl",
				"includeParams": [
					"loginUsername",
					"loginPassword",
					"ustreamHomePath",
					"ustreamExecutorPath",
					"flinkHomePath",
					"flinkHistoryRestAddress",
					"yarnRmHttpAddress",
					"s3Endpoint",
					"s3AccessKey",
					"s3Secretkey",
					"s3Bucket",
					"s3BasePath",
					"dbUrl",
					"dbUser",
					"dbPassword",
					"redisHost",
					"redisPort",
					"redisUsername",
					"redisPassword",
					"encryptorPassword"
				]
			}
		]
	},
	"parameters": [
