{
	"name": "USTREAM",
	"label": "Ustream",
	"description": "数衍实时组件",
	"version": "3.4.0",
	"sortNum": 78,
	"dependencies": ["FLINK"],
	"packageName": "ustream-3.4.0-bin.tar.gz",
	"decompressPackageName": "ustream-3.4.0",
	"roles": [{
			"name": "UstreamServer",
			"label": "UstreamServer",
			"roleType": "master",
			"runAs": {
				"user": "hive",
				"group": "hadoop"
			},
			"cardinality": "1",
			"logFile": "logs/ustream.log",
			"jmxPort": 9112,
			"startRunner": {
				"timeout": "60",
				"program": "bin/ustream-daemon.sh",
				"args": ["start", "server"]
			},
			"stopRunner": {
				"timeout": "600",
				"program": "bin/ustream-daemon.sh",
				"args": ["stop", "server"]
			},
			"statusRunner": {
				"timeout": "60",
				"program": "bin/ustream-daemon.sh",
				"args": ["status", "server"]
			},
			"restartRunner": {
				"timeout": "60",
				"program": "bin/ustream-daemon.sh",
				"args": ["restart", "server"]
			}
		}
	],
	"configWriter": {
		"generators": [{
				"filename": "application.yaml",
				"configFormat": "custom",
				"outputDirectory": "conf/",
				"templateName": "ustream-yaml.ftl",
				"includeParams": [
					"loginUsername",
					"loginPassword",
					"ustreamHomePath",
					"ustreamExecutorPath",
					"flinkHomePath",
					"flinkHistoryRestAddress",
					"yarnRmHttpAddress",
					"ustreamS3Endpoint",
					"ustreamS3AccessKey",
					"ustreamS3Secretkey",
					"ustreamS3Bucket",
					"ustreamS3BasePath",
					"dbUrl",
					"dbUser",
					"dbPassword",
					"ustreamRedisHost",
					"ustreamRedisPort",
					"ustreamRedisUsername",
					"ustreamRedisPassword",
					"encryptorPassword"
				]
			}
		]
	},
	"parameters": [
		{
			"name": "loginUsername",
			"label": "登录用户",
			"description": "",
			"configType": "map",
			"required": true,
			"type": "input",
			"value": "",
			"configurableInWizard": true,
			"hidden": false,
			"defaultValue": "admin"
		},
		{
			"name": "loginPassword",
			"label": "登录密码",
			"description": "",
			"configType": "map",
			"required": true,
			"type": "input",
			"value": "",
			"configurableInWizard": true,
			"hidden": false,
			"defaultValue": "y@iyTr18UID"
		},
		{
