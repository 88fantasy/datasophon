{
  "name": "NACOS",
  "label": "Nacos",
  "description": "服务注册发现、服务配置管理",
  "version": "2.4.2.1",
  "sortNum": 80,
  "dependencies": [],
  "packageName": "nacos-server-2.4.2.1.tar.gz",
  "decompressPackageName": "nacos-server-2.4.2.1",
  "roles": [{
    "name": "NacosServer",
    "label": "NacosServer",
    "roleType": "master",
    "cardinality": "1",
    "runAs": {},
    "logFile": "logs/start.out",
    "resourceStrategies":[{
      "type": "download",
      "from": "script/control_nacos.sh",
      "to": "control_nacos.sh"
    }],
    "startRunner": {
      "timeout": "60",
      "program": "control_nacos.sh",
      "args": [
        "start",
        "standalone"
      ]
    },
    "stopRunner": {
      "timeout": "600",
      "program": "control_nacos.sh",
      "args": [
        "stop",
        "standalone"
      ]
    },
    "statusRunner": {
      "timeout": "60",
      "program": "control_nacos.sh",
      "args": [
        "status",
        "standalone"
      ]
    },
    "externalLink": {
      "name": "Nacos UI",
      "label": "Nacos UI",
      "url": "http://${host}:${nacosServerPort}/nacos/"
    }
  }],
  "configWriter": {
    "generators": [
      {
        "filename": "application.properties",
        "configFormat": "custom",
        "outputDirectory": "conf",
        "templateName": "nacos-server-master.ftl",
        "includeParams": [
            "nacosServerPort",
            "nacosDbUrl",
            "nacosDbUser",
            "nacosDbPwd",
            "nacosAuthEnabled",
            "nacosTokenSecretKey"
        ]
      },
      {
        "filename": "nacos-user-mgmt.properties",
        "configFormat": "properties",
        "outputDirectory": "conf",
        "includeParams": [
            "nacosUsername",
            "nacosPassword"
        ]
      }
    ]
  },
  "parameters": [
    {
      "name": "nacosServerPort",
      "label": "端口",
      "description": "端口",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "8848",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "8848"
    },
    {
      "name": "nacosDbUrl",
      "label": "第一个数据库的URL",
      "description": "第一个数据库的URL",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "jdbc:mysql://${apiHost}:3306/nacos?useUnicode=true&characterEncoding=UTF8&autoReconnect=true&useAffectedRows=true&useSSL=false"
    },
    {
      "name": "nacosDbUser",
      "label": "数据库用户名",
      "description": "数据库用户名",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "nacos"
    },
    {
      "name": "nacosDbPwd",
      "label": "数据库密码",
      "description": "数据库密码",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "nacos"
    },
    {
      "name": "nacosAuthEnabled",
      "label": "是否启用认证",
      "description": "是否启用认证",
      "required": true,
      "configType": "map",
      "type": "switch",
      "value": true,
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": true
    },
    {
      "name": "nacosTokenSecretKey",
      "label": "密钥",
      "description": "密钥",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "a73d81760ee6fe6a0c2482e0b79a409ce810ec969b6cf5e27bb81d822449b9ea",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "a73d81760ee6fe6a0c2482e0b79a409ce810ec969b6cf5e27bb81d822449b9ea"
    },
    {
      "name": "nacosUsername",
      "label": "用户名",
      "description": "登录用户名",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "nacos",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "nacos"
    },
    {
      "name": "nacosPassword",
      "label": "密码",
      "description": "登录密码",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "nacos",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "nacos"
    }
  ]
}