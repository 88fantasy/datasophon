{
  "name": "SPARK3",
  "label": "Spark3",
  "description": "分布式计算系统",
  "version": "3.4.2",
  "sortNum": 7,
  "dependencies": [
    "HIVE"
  ],
  "packageName": "spark-3.4.2-bin-hadoop3.tgz",
  "decompressPackageName": "spark-3.4.2-bin-hadoop3",
  "roles": [
    {
      "name": "SparkClient3",
      "label": "SparkClient3",
      "roleType": "client",
      "runAs": {
        "user": "hive",
        "group": "hadoop"
      },
      "cardinality": "1+",
      "logFile": "logs/hadoop-${user}-datanode-${host}.log",
      "resourceStrategies": [
        {
          "type": "sh",
          "commands": [
            [
              "mkdir",
              "logs"
            ],
            [
              "cp",
              "/data/install_datasophon/datasophon-worker/lib/mysql-connector-java-8.0.28.jar",
              "jars/"
            ]
          ]
        },
        {
          "type": "nexus",
          "from": "iceberg-spark-runtime-3.4_2.12-1.3.1.jar",
          "to": "jars/iceberg-spark-runtime-3.4_2.12-1.3.1.jar"
        },
        {
          "type": "nexus",
          "from": "spark-doris-connector-spark-3.4-25.2.0.jar",
          "to": "jars/spark-doris-connector-spark-3.4-25.2.0.jar"
        }
      ]
    },
    {
      "name": "SparkThriftServer",
      "label": "SparkThriftServer",
      "roleType": "worker",
      "runAs": {
        "user": "hive",
        "group": "hadoop"
      },
      "cardinality": "1",
      "logFile": "logs/spark-hive-org.apache.spark.sql.hive.thriftserver.HiveThriftServer2-1-${host}.out",
      "resourceStrategies": [
        {
          "type": "download",
          "from": "script/control_spark_thrift.sh",
          "to": "control_spark_thrift.sh"
        }
      ],
      "startRunner": {
        "timeout": "60",
        "program": "control_spark_thrift.sh",
        "args": [
          "start"
        ]
      },
      "stopRunner": {
        "timeout": "600",
        "program": "control_spark_thrift.sh",
        "args": [
          "stop"
        ]
      },
      "statusRunner": {
        "timeout": "60",
        "program": "control_spark_thrift.sh",
        "args": [
          "status"
        ]
      },
      "restartRunner": {
        "timeout": "60",
        "program": "control_spark_thrift.sh",
        "args": [
          "restart"
        ]
      }
    }
  ],
  "configWriter": {
    "generators": [
      {
        "filename": "spark-env.sh",
        "configFormat": "custom",
        "templateName": "spark-env.ftl",
        "outputDirectory": "conf",
        "includeParams": [
          "SPARK_DIST_CLASSPATH",
          "HADOOP_CONF_DIR",
          "YARN_CONF_DIR",
          "custom.spark.env.sh"
        ]
      },
      {
        "filename": "spark-defaults.conf",
        "configFormat": "properties2",
        "outputDirectory": "conf",
        "includeParams": [
          "custom.spark.defaults.conf"
        ]
      }
    ]
  },
  "parameters": [
    {
      "name": "SPARK_DIST_CLASSPATH",
      "label": "spark加载Classpath路径",
      "description": "",
      "required": true,
      "configType": "map",
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "$(${HADOOP_HOME}/bin/hadoop classpath)"
    },
    {
      "name": "HADOOP_CONF_DIR",
      "label": "Hadoop配置文件目录",
      "description": "",
      "configType": "map",
      "required": true,
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "${HADOOP_HOME}/etc/hadoop"
    },
    {
      "name": "YARN_CONF_DIR",
      "label": "Yarn配置文件目录",
      "description": "",
      "configType": "map",
      "required": true,
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "${HADOOP_HOME}/etc/hadoop"
    },
    {
      "name": "custom.spark.env.sh",
      "label": "自定义配置spark-env.sh",
      "description": "自定义配置spark-env.sh",
      "configType": "custom",
      "required": false,
      "type": "multipleWithKey",
      "value": [
        {
          "SPARK_CLASSPATH": "${ROOT.VosManager.INSTALL_PATH}/spark3/carbonlib/*"
        },
        {
          "HIVE_HOME": "${ROOT.VosManager.INSTALL_PATH}/hive"
        }
      ],
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": []
    },
    {
      "name": "custom.spark.defaults.conf",
      "label": "自定义配置spark-defaults.conf",
      "description": "自定义配置",
      "configType": "custom",
      "required": false,
      "type": "multipleWithKey",
      "value": [
        {"spark.sql.hive.metastore.jars": "/data/install_datasophon/lib/*"},
        {"spark.sql.hive.metastore.version": "3.1.3"},
        {"spark.yarn.jars": "hdfs:///spark3/jars/*.jar"},
        {"spark.port.maxRetries": "100"},
        {"spark.sql.catalogImplementation": "hive"},
        {"spark.sql.uri": "${HIVE.hive.metastore.uris}"},
        {"spark.sql.extensions": "org.apache.iceberg.spark.extensions.IcebergSparkSessionExtensions,org.apache.paimon.spark.extensions.PaimonSparkSessionExtensions"},
        {"spark.sql.warehouse.dir": "/user/hive/warehouse"},
        {"spark.sql.catalog.paimon_catalog": "org.apache.paimon.spark.SparkCatalog"},
        {"spark.sql.catalog.paimon_catalog.metastore": "hive"},
        {"spark.sql.catalog.paimon_catalog.uri": "${HIVE.hive.metastore.uris}"},
        {"spark.sql.catalog.paimon_catalog.warehouse": "hdfs:///user/hive/warehouse"},
        {"spark.sql.catalog.doris_catalog": "org.apache.doris.spark.catalog.DorisTableCatalog"},
        {"spark.sql.catalog.doris_catalog.doris.fenodes": "${DORIS.feMaster}:${DORIS.http_port}"},
        {"spark.sql.catalog.doris_catalog.doris.query.port": "${DORIS.query_port}"},
        {"spark.sql.catalog.doris_catalog.doris.user": "root"},
        {"spark.sql.catalog.doris_catalog.doris.password": "${DORIS.root_password}"}
      ],
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": []
    }
  ]
}