  "roles": [
    {
      "name": "OperationbrainServer",
      "label": "OperationbrainServer",
      "roleType": "master",
      "cardinality": "1",
      "logFile": "module/chinaunicom-medical-archtype-operationbrain-server/logs/operationbrain-server-info.log",
      "jmxPort": 11002,
      "resourceStrategies": [
        {
          "type":"frontend",
          "meta": "${juicefsMeta}",
          "source": "module/view/hospital-index-monitor-view",
          "target": "/hospital-index-monitor-view"
        },
        {
          "type":"frontend",
          "meta": "${juicefsMeta}",
          "source": "module/view/operational-decision-center-view",
          "target": "/operational-decision-center-view"
        },
        {
          "type":"frontend",
          "meta": "${juicefsMeta}",
          "source": "module/view/smart-operation-brain-home-view",
          "target": "/smart-operation-brain-home-view"
        }
      ],
      "startRunner": {
        "timeout": "60",
        "program": "module/chinaunicom-medical-archtype-operationbrain-server/bin/server.sh",
        "args": [
          "start"
        ]
      },
      "stopRunner": {
        "timeout": "60",
        "program": "module/chinaunicom-medical-archtype-operationbrain-server/bin/server.sh",
        "args": [
          "stop"
        ]
      },
      "statusRunner": {
        "timeout": "60",
        "program": "module/chinaunicom-medical-archtype-operationbrain-server/bin/server.sh",
        "args": [
          "status"
        ]
      },
      "restartRunner": {
        "timeout": "60",
        "program": "module/chinaunicom-medical-archtype-operationbrain-server/bin/server.sh",
        "args": [
          "restart"
        ]
      }
    },
    {
      "name": "Indicator",
      "label": "Indicator",
      "roleType": "master",
      "cardinality": "1",
      "logFile": "module/chinaunicom-medical-capacity-indicator/logs/indicator.log",
      "jmxPort": 11003,
      "startRunner": {
        "timeout": "60",
        "program": "module/chinaunicom-medical-capacity-indicator/bin/server.sh",
        "args": [
          "start"
        ]
      },
      "stopRunner": {
        "timeout": "60",
        "program": "module/chinaunicom-medical-capacity-indicator/bin/server.sh",
        "args": [
          "stop"
        ]
      },
      "statusRunner": {
        "timeout": "60",
        "program": "module/chinaunicom-medical-capacity-indicator/bin/server.sh",
        "args": [
          "status"
        ]
      },
      "restartRunner": {
        "timeout": "60",
        "program": "module/chinaunicom-medical-capacity-indicator/bin/server.sh",
        "args": [
          "restart"
        ]
      }
    }
