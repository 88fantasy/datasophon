{
  "name": "RESEARCH",
  "label": "Research",
  "description": "科研检索",
  "version": "2.0.0",
  "sortNum": 1,
  "dependencies":["NACOS"],
  "packageName": "research-server-2.0.0-RELEASE-install.tar.gz",
  "decompressPackageName": "research-server-2.0.0-RELEASE",
  "roles": [
    {
      "name": "ResearchPlatform",
      "label": "ResearchPlatform",
      "roleType": "master",
      "cardinality": "1",
      "logFile": "module/chinaunicom-medical-research-platform/logs/chinaunicom-medical-research-platform.log",
      "jmxPort": 11001,
      "resourceStrategies": [
        {
          "type":"frontend",
          "meta": "${juicefsMeta}",
          "source": "module/view/research-platform-view",
          "target": "/research-platform-view",
          "conf": "gateway-research.conf"
        },
        {
          "type":"frontend",
          "meta": "${juicefsMeta}",
          "source": "module/view/scientific-research-view",
          "target": "/scientific-research-view",
          "conf":"gateway-research.conf"
        },
        {
          "type":"frontend",
          "meta": "${juicefsMeta}",
          "source": "module/view/research-service-platform-view",
          "target": "/research-service-platform-view",
          "conf":"gateway-research.conf"
        }
      ],
      "startRunner": {
        "timeout": "60",
        "program": "module/chinaunicom-medical-research-platform/bin/server.sh",
        "args": [
          "start"
        ]
      },
      "stopRunner": {
        "timeout": "60",
        "program": "module/chinaunicom-medical-research-platform/bin/server.sh",
        "args": [
          "stop"
        ]
      },
      "statusRunner": {
        "timeout": "60",
        "program": "module/chinaunicom-medical-research-platform/bin/server.sh",
        "args": [
          "status"
        ]
      },
      "restartRunner": {
        "timeout": "60",
        "program": "module/chinaunicom-medical-research-platform/bin/server.sh",
        "args": [
          "restart"
        ]
      }
    },
    {
      "name": "AppRetrieval",
      "label": "AppRetrieval",
      "roleType": "master",
      "cardinality": "1",
      "logFile": "module/chinaunicom-medical-app-retrieval/logs/chinaunicom-medical-app-retrieval.log",
      "jmxPort": 11000,
      "startRunner": {
        "timeout": "60",
        "program": "module/chinaunicom-medical-app-retrieval/bin/server.sh",
        "args": [
          "start"
        ]
      },
      "stopRunner": {
        "timeout": "60",
        "program": "module/chinaunicom-medical-app-retrieval/bin/server.sh",
        "args": [
          "stop"
        ]
      },
      "statusRunner": {
        "timeout": "60",
        "program": "module/chinaunicom-medical-app-retrieval/bin/server.sh",
        "args": [
          "status"
        ]
      },
      "restartRunner": {
        "timeout": "60",
        "program": "module/chinaunicom-medical-app-retrieval/bin/server.sh",
        "args": [
          "restart"
        ]
      }
    }
  ],
