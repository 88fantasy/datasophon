  "version": "3.6.1",
  "sortNum": 79,
  "dependencies":["NACOS"],
  "packageName": "bigdata-server.tar.gz",
  "decompressPackageName": "bigdata-server",
  "roles": [
    {
      "name": "BigData",
      "label": "BigData",
      "roleType": "master",
      "cardinality": "1",
      "logFile": "bigdata/logs/chinaunicom-medical-mgmt-bigdata-server.log",
      "startRunner": {
        "timeout": "60",
        "program": "bigdata/bin/bigdata-server.sh",
        "args": [
          "start"
        ]
      },
      "stopRunner": {
        "timeout": "60",
        "program": "bigdata/bin/bigdata-server.sh",
        "args": [
          "stop"
        ]
      },
      "statusRunner": {
        "timeout": "60",
        "program": "bigdata/bin/bigdata-server.sh",
        "args": [
          "status"
        ]
      },
      "restartRunner": {
        "timeout": "60",
        "program": "bigdata/bin/bigdata-server.sh",
        "args": [
          "restart"
        ]
      },
      "externalLink": {
        "name": "BigData UI",
        "label": "BigData UI",
        "url": "http://${host}:${bigdataServerPort}/bigdata/workbench-view#/login"
      }
    },
    {
      "name": "hsbServer",
      "label": "hsbServer",
      "roleType": "worker",
      "cardinality": "0+",
      "logFile": "hsb/logs/chinaunicom-medical-mgmt-hsb-server.log",
      "startRunner": {
        "timeout": "60",
        "program": "hsb/bin/hsb-server.sh",
        "args": [
          "start"
        ]
      },
      "stopRunner": {
        "timeout": "60",
        "program": "hsb/bin/hsb-server.sh",
        "args": [
          "stop"
        ]
      },
      "statusRunner": {
        "timeout": "60",
        "program": "hsb/bin/hsb-server.sh",
        "args": [
          "status"
        ]
      },
      "restartRunner": {
        "timeout": "60",
        "program": "hsb/bin/hsb-server.sh",
        "args": [
          "restart"
        ]
      }
    }
  ],
