{
  "name": "BIGDATA",
  "label": "BigData",
  "description": "数衍工作台",
  "version": "3.6.1",
  "sortNum": 79,
  "dependencies":[],
  "packageName": "bigdata-server.tar.gz",
  "decompressPackageName": "bigdata-server",
  "roles": [
    {
      "name": "BigData",
      "label": "BigData",
      "roleType": "master",
      "cardinality": "1",
      "logFile": "bigdata/logs/chinaunicom-medical-mgmt-bigdata-server.log",
      "startRunner": {
        "timeout": "60",
        "program": "bigdata/bin/bigdata-server.sh",
        "args": [
          "start"
        ]
      },
      "stopRunner": {
        "timeout": "60",
        "program": "bigdata/bin/bigdata-server.sh",
        "args": [
          "stop"
        ]
      },
      "statusRunner": {
        "timeout": "60",
        "program": "bigdata/bin/bigdata-server.sh",
        "args": [
          "status"
        ]
      },
      "restartRunner": {
        "timeout": "60",
        "program": "bigdata/bin/bigdata-server.sh",
        "args": [
          "restart"
        ]
      },
      "externalLink": {
        "name": "BigData UI",
        "label": "BigData UI",
        "url": "${bigdataServerAddress}/workbench-view#/login"
      }
    },
    {
      "name": "hsbServer",
      "label": "hsbServer",
      "roleType": "worker",
      "cardinality": "0+",
      "logFile": "hsb/logs/chinaunicom-medical-mgmt-hsb-server.log",
      "startRunner": {
        "timeout": "60",
        "program": "hsb/bin/hsb-server.sh",
        "args": [
          "start"
        ]
      },
      "stopRunner": {
        "timeout": "60",
        "program": "hsb/bin/hsb-server.sh",
        "args": [
          "stop"
        ]
      },
      "statusRunner": {
        "timeout": "60",
        "program": "hsb/bin/hsb-server.sh",
        "args": [
          "status"
        ]
      },
      "restartRunner": {
        "timeout": "60",
        "program": "hsb/bin/hsb-server.sh",
        "args": [
          "restart"
        ]
      }
    }
  ],
  "configWriter": {
    "generators": [
      {
        "filename": "bigdata/conf/bootstrap.yaml",
        "configFormat": "custom",
        "outputDirectory": "",
        "templateName": "bigdata-master.ftl",
        "includeParams": [
          "bigdataJasyptEncryptorPassword",
          "bigdataServerAddress",
          "bigdataAppProfile",
          "bigdataAppNacosGroup",
          "bigdataAppNacosHost",
          "bigdataAppNacosPort",
          "bigdataAppNacosUsername",
          "bigdataAppNacosPassword",
          "bigdataAppVersion",
          "bigdataAppName",
          "bigdataMysqlBigdataUrl",
          "bigdataMysqlBigdataUsername",
          "bigdataMysqlBigdataPassword"
        ]
      },
      {
        "filename": "hsb/conf/bootstrap.yaml",
        "configFormat": "custom",
        "outputDirectory": "",
        "templateName": "hsb-master.ftl",
        "includeParams": [
          "bigdataJasyptEncryptorPassword",
          "bigdataAppProfile",
          "bigdataAppNacosGroup",
          "bigdataAppNacosHost",
          "bigdataAppNacosPort",
          "bigdataAppNacosUsername",
          "bigdataAppNacosPassword",
          "hsbAppName"
        ]
      },
      {
        "filename": "common-vars.yml",
        "configFormat": "nacos_config",
        "outputDirectory": "conf",
        "includeParams": [
          "bigdataNacosCommonVarsConf"
        ]
      }
    ]
  },
  "parameters": [
    {
      "name": "bigdataJasyptEncryptorPassword",
