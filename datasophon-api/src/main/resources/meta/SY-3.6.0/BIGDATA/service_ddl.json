          "bigdataEsNodes",
          "bigdataEsUserName",
          "bigdataEsPassword",
          "bigdataWorkbenchSystemGetTokenUrl",
          "bigdataWorkbenchSystemCheckToken",
          "bigdataWorkbenchSystemQueryRootMenu",
          "bigdataWorkbenchSystemRedirectUri",
          "bigdataWorkbenchSystemAuthorizationUri",
