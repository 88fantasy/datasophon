{
  "name": "BIGDATA",
  "label": "BigData",
  "description": "数衍工作台",
  "version": "3.6.1",
  "sortNum": 79,
  "dependencies":[],
  "packageName": "bigdata-3.6.1.tar.gz",
  "decompressPackageName": "bigdata-3.6.1",
  "roles": [
    {
      "name": "BigData",
      "label": "BigData",
      "roleType": "master",
      "cardinality": "1",
      "logFile": "nohup.out logs/chinaunicom-medical-mgmt-bigdata-server.log",
      "startRunner": {
        "timeout": "60",
        "program": "bin/bigdata-server.sh",
        "args": [
          "start"
        ]
      },
      "stopRunner": {
        "timeout": "600",
        "program": "bin/bigdata-server.sh",
        "args": [
          "stop"
        ]
      },
      "statusRunner": {
        "timeout": "60",
        "program": "bin/bigdata-server.sh",
        "args": [
          "status"
        ]
      },
      "restartRunner": {
        "timeout": "60",
        "program": "bin/bigdata-server.sh",
        "args": [
          "restart"
        ]
      },
      "externalLink": {
        "name": "BigData UI",
        "label": "BigData UI",
        "url": "${bigdataServer}"
      }
    }
  ],
  "configWriter": {
    "generators": [
      {
        "filename": "bootstrap.yaml",
        "configFormat": "custom",
        "outputDirectory": "",
        "templateName": "bigdata-master.ftl",
        "includeParams": [
          "jasyptEncryptorPassword",
          "bigdataServerAddress",
          "appProfile",
          "appNacosGroup",
          "appNacosHost",
          "appNacosPort",
          "appNacosUsername",
          "appNacosPassword",
          "appVersion",
          "datasourceConfig"
        ]
      },
      {
        "filename": "common-vars.yml",
        "configFormat": "properties",
        "outputDirectory": "conf",
        "includeParams": [
          "nacosCommonVarsConf"
        ]
      }
    ]
  },
  "parameters": [
    {
      "name": "datasourceConfig",
      "label": "bigdata数据库配置",
      "description": "bigdata数据库配置",
      "required": true,
      "configType": "custom",
      "type": "multipleWithKey",
      "value": [
        {"mysqlBigdataUrl":"jdbc:mysql://192.168.2.122:3306/chinaunicom_medical_mgmt_bigdata_ds?&allowMultiQueries=true&characterEncoding=utf-8"},
        {"mysqlBigdataUsername":"root"},
        {"mysqlBigdataPassword":"datasophon"}
      ],
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": ""
    },
    {
      "name": "bigdataServer",
      "label": "bigdata首页",
      "description": "bigdata首页",
      "required": true,
      "configType": "map",
