{
  "name": "FLINK",
  "label": "Flink",
  "description": "实时计算引擎",
  "version": "1.16.2",
  "sortNum": 6,
  "dependencies":[],
  "packageName": "flink-1.16.2-3.4.0.tar.gz",
  "decompressPackageName": "flink-1.16.2",
  "roles": [
    {
      "name": "FlinkClient",
      "label": "FlinkClient",
      "roleType": "client",
      "runAs": {
        "user": "hive",
        "group": "hadoop"
      },
      "cardinality": "1+",
      "logFile": "log/flink-hive-client-${host}.log",
      "resourceStrategies":[
        {
          "type": "link",
          "source": "/opt/datasophon/flink-1.16.2/opt/flink-s3-fs-hadoop-1.16.2.jar",
          "target": "plugins/s3-fs-hadoop/flink-s3-fs-hadoop-1.16.2.jar"
        },
        {
          "type": "append_line",
          "source": "bin/config.sh",
          "line": 19,
          "text": "export JAVA_HOME=/usr/local/jdk1.8.0_333"
        },
        {
          "type": "append_line",
          "source": "bin/config.sh",
          "line": 20,
          "text": "export HADOOP_CLASSPATH=`/opt/datasophon/hadoop/bin/hadoop classpath`"
        }
      ]
    },
    {
      "name": "FlinkHistory",
      "label": "FlinkHistory",
      "roleType": "worker",
      "runAs": {
        "user": "hive",
        "group": "hadoop"
      },
      "cardinality": "1",
      "logFile": "log/flink-hive-historyserver-1-${host}.log",
      "resourceStrategies":[{
        "type": "download",
        "from": "script/control_history.sh",
        "to": "control_history.sh",
        "md5": "5c45caf5e57d8f203f9936d830b835bb"
      },{
          "type": "link",
          "source": "/opt/datasophon/flink-1.16.2/opt/flink-s3-fs-hadoop-1.16.2.jar",
          "target": "plugins/s3-fs-hadoop/flink-s3-fs-hadoop-1.16.2.jar"
        },
        {
          "type": "append_line",
          "source": "bin/config.sh",
          "line": 19,
          "text": "export JAVA_HOME=/usr/local/jdk1.8.0_333"
        },
        {
          "type": "append_line",
          "source": "bin/config.sh",
          "line": 20,
          "text": "export HADOOP_CLASSPATH=`/opt/datasophon/hadoop/bin/hadoop classpath`"
        }],
      "startRunner": {
        "timeout": "60",
        "program": "control_history.sh",
        "args": ["start"]
      },
      "stopRunner": {
        "timeout": "600",
        "program": "control_history.sh",
        "args": ["stop"]
      },
      "statusRunner": {
        "timeout": "60",
        "program": "control_history.sh",
        "args": ["status"]
      },
      "restartRunner": {
        "timeout": "60",
        "program": "control_history.sh",
        "args": ["restart"]
      },
      "externalLink": {
        "name": "History UI",
        "label": "History UI",
        "url": "http://${host}:8082"
      }
    }
  ],
  "configWriter": {
    "generators": [
      {
        "filename": "flink-conf.yaml",
        "configFormat": "custom",
        "templateName": "properties3.ftl",
        "outputDirectory": "conf",
        "includeParams": [
          "jobmanager.memory.process.size",
          "taskmanager.memory.process.size",
          "state.backend",
          "state.checkpoints.dir",
          "state.savepoints.dir",
          "state.backend.incremental",
          "jobmanager.archive.fs.dir",
          "historyserver.web.port",
          "historyserver.archive.fs.dir",
          "historyserver.web.tmpdir",
          "classloader.check-leaked-classloader",
          "fs.allowed-fallback-filesystems",
          "s3.access-key",
          "s3.secret-key",
          "s3.endpoint",
          "s3.path.style.access",
          "custom.flink.conf.yaml"
        ]
      }
    ]
  },
  "parameters": [
