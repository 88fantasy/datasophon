{
  "name": "FLINK",
  "label": "Flink",
  "description": "实时计算引擎",
  "version": "1.16.2",
  "sortNum": 6,
  "dependencies":[],
  "packageName": "flink-1.16.2-3.4.0.tar.gz",
  "decompressPackageName": "flink-1.16.2",
  "runAs":"root",
  "roles": [
    {
      "name": "FlinkClient",
      "label": "FlinkClient",
      "roleType": "client",
      "runAs": {
        "user": "hive",
        "group": "hadoop"
      },
      "cardinality": "1+",
      "logFile": "logs/flink.log"
    }
  ],
  "configWriter": {
    "generators": [
      {
        "filename": "flink-conf.yaml",
        "configFormat": "custom",
        "templateName": "properties3.ftl",
        "outputDirectory": "conf",
        "includeParams": [
          "jobmanager.memory.heap.size",
          "taskmanager.memory.flink.size",
          "state.backend",
          "state.checkpoints.dir",
          "state.savepoints.dir",
          "state.backend.incremental",
          "jobmanager.archive.fs.dir",
          "historyserver.web.port",
          "historyserver.archive.fs.dir",
          "historyserver.web.tmpdir",
          "classloader.check-leaked-classloader",
          "fs.allowed-fallback-filesystems",
          "s3.access-key",
          "s3.secret-key",
          "s3.endpoint",
          "s3.path.style.access",
          "custom.flink.conf.yaml"
        ]
      }
    ]
  },
  "parameters": [
    {
      "name": "jobmanager.memory.heap.size",
      "label": "jobmanager堆内存大小",
      "description": "",
      "required": false,
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "1600m"
    },
    {
      "name": "taskmanager.memory.flink.size",
      "label": "taskmanager堆内存大小",
      "description": "",
      "required": false,
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "1280m"
    },
    {
      "name": "state.backend",
      "label": "状态持久化",
      "description": "",
      "required": true,
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "rocksdb"
    },
    {
      "name": "state.checkpoints.dir",
      "label": "状态检查点持久化目录",
      "description": "",
      "required": true,
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "s3://public/capacity/basic/ustream/flink/checkpoints/"
    },
    {
      "name": "state.savepoints.dir",
      "label": "状态保存点持久化目录",
      "description": "",
      "required": true,
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "s3://public/capacity/basic/ustream/flink/savepoints/"
    },
    {
      "name": "state.backend.incremental",
      "label": "开启增量快照",
      "description": "",
      "required": true,
      "type": "switch",
      "value": true,
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": true
    },
    {
      "name": "jobmanager.archive.fs.dir",
      "label": "作业存档目录",
      "description": "",
      "required": true,
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "s3://public/capacity/basic/ustream/flink/completed-jobs/"
    },
    {
      "name": "historyserver.web.port",
      "label": "HistoryServer页面端口",
      "description": "",
      "required": true,
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "8082"
    },
    {
      "name": "historyserver.archive.fs.dir",
      "label": "监视目录列表(以逗号分隔的)",
      "description": "",
      "required": true,
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "s3://public/capacity/basic/ustream/flink/completed-jobs/"
    },
    {
      "name": "historyserver.web.tmpdir",
      "label": "HistoryServer临时目录",
      "description": "",
      "required": true,
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "/data/unimedical/appsrv/ustream/flink/tmp/flink-web-history"
    },
    {
      "name": "classloader.check-leaked-classloader",
      "label": "禁用classloader.check",
      "description": "禁用classloader.check",
      "required": true,
      "type": "switch",
      "value": false,
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": false
    },
    {
      "name": "fs.allowed-fallback-filesystems",
      "label": "保存点模式",
      "description": "",
      "required": true,
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "s3"
    },
    {
      "name": "s3.access-key",
      "label": "S3帐号",
      "description": "",
      "required": true,
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "cuminio"
    },
    {
      "name": "s3.secret-key",
      "label": "S3密钥",
      "description": "",
      "required": true,
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "u4Gkp19TRcKKlTCLNA1pyA=="
    },
    {
      "name": "s3.endpoint",
      "label": "S3地址",
      "description": "",
      "required": true,
      "type": "input",
      "value": "",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "http://minio-node-1:9000"
    },
    {
      "name": "s3.path.style.access",
      "label": "启用路径样式",
      "description": "",
      "required": true,
      "type": "switch",
      "value": true,
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": true
    },
    {
      "name": "custom.flink.conf.yaml",
      "label": "自定义配置flink-conf.yaml",
      "description": "自定义配置",
      "configType": "custom",
      "required": false,
      "type": "multipleWithKey",
      "value": [],
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": ""
    }
  ]
}