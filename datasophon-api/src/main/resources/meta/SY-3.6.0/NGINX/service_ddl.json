        "filename": "configure.sh",
        "configFormat": "custom",
        "outputDirectory": "bin",
        "templateName": "nginx-configure.ftl",
        "includeParams": [
          "nginxBasePath",
          "nginxInstallPath",
          "nginxModules"
        ]
      },
      {
        "filename": "nginx.conf",
        "configFormat": "custom",
        "outputDirectory": "nginx/conf",
