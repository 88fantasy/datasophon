        "templateName": "nginx-server-conf.ftl",
        "includeParams": [
          "nginxServerPort",
          "nginxWebPort",
          "nginxInstallPath"
        ]
      },
      {
        "filename": "20011.conf",
        "configFormat": "custom",
        "outputDirectory": "nginx/conf/confs/inside_of_http_confs",
        "templateName": "nginx-web-conf.ftl",
        "includeParams": [
          "nginxWebPort",
          "nginxWebappPath"
        ]
      },
      {
        "filename": "gateway.conf",
        "configFormat": "custom",
        "outputDirectory": "nginx/conf/confs/inside_of_http_confs/app-confs",
        "templateName": "nginx-app-conf.conf",
        "includeParams": [
          "nginxProxyUrl",
          "nginxAppName",
          "nginxAppPort"
        ]
      }
    ]
  },
