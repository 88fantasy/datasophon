{
  "name": "NGINX",
  "label": "Nginx",
  "description": "Nginx网关",
  "version": "1.26.2",
  "sortNum": 93,
  "dependencies":["JUICEFS"],
  "packageName": "nginx-1.26.2.tar.gz",
  "decompressPackageName": "nginx-1.26.2",
  "roles": [
    {
      "name": "Nginx",
      "label": "Nginx",
      "roleType": "master",
      "cardinality": "1+",
      "logFile": "nginx/logs/access/access.log",
      "jmxPort": 9099,
      "resourceStrategies":[{
        "type": "download",
        "from": "script/control.sh",
        "to": "bin/control.sh",
        "md5": "8c31a7ef7b949b52e083cd7d408647b6"
      }],
      "startRunner": {
        "timeout": "60",
        "program": "bin/control.sh",
        "args": [
          "start"
        ]
      },
      "stopRunner": {
        "timeout": "600",
        "program": "bin/control.sh",
        "args": [
          "stop"
        ]
      },
      "statusRunner": {
        "timeout": "60",
        "program": "bin/control.sh",
        "args": [
          "status"
        ]
      },
      "restartRunner": {
        "timeout": "60",
        "program": "bin/control.sh",
        "args": [
          "restart"
        ]
      }
    }
  ],
  "configWriter": {
    "generators": [
      {
        "filename": "configure.sh",
        "configFormat": "custom",
        "outputDirectory": "bin",
        "templateName": "nginx-configure.ftl",
        "includeParams": [
          "nginxBasePath",
          "nginxInstallPath",
          "nginxModules"
        ]
      },
      {
        "filename": "nginx.conf",
        "configFormat": "custom",
        "outputDirectory": "nginx/conf",
        "templateName": "nginx-conf.ftl",
        "includeParams": [
          "nginxWorkerProcesses"
        ]
      },
      {
        "filename": "19000.conf",
        "configFormat": "custom",
        "outputDirectory": "nginx/conf/confs/inside_of_http_confs",
        "templateName": "nginx-server-conf.ftl",
        "includeParams": [
          "nginxServerPort",
          "nginxWebPort",
          "nginxInstallPath"
        ]
      },
      {
        "filename": "20011.conf",
        "configFormat": "custom",
        "outputDirectory": "nginx/conf/confs/inside_of_http_confs",
        "templateName": "nginx-web-conf.ftl",
        "includeParams": [
          "nginxWebPort",
          "nginxWebappPath"
        ]
      },
      {
        "filename": "gateway.conf",
        "configFormat": "custom",
        "outputDirectory": "nginx/conf/confs/inside_of_http_confs/app-confs",
        "templateName": "nginx-app-conf.ftl",
        "includeParams": [
          "nginxAppConf"
        ]
      }
    ]
  },
  "parameters": [
    {
      "name": "nginxBasePath",
      "key": "nginxBasePath",
      "label": "nginx位置",
      "description": "nginx位置",
      "required": true,
      "type": "input",
      "configType": "map",
      "value": "/opt/datasophon/nginx-1.26.2",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "/opt/datasophon/nginx-1.26.2"
    },
    {
      "name": "nginxInstallPath",
      "key": "nginxInstallPath",
      "label": "nginx安装的位置",
      "description": "nginx安装的位置",
      "required": true,
      "type": "input",
      "configType": "map",
      "value": "/opt/datasophon/nginx-1.26.2/nginx",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "/opt/datasophon/nginx-1.26.2/nginx"
    },
    {
