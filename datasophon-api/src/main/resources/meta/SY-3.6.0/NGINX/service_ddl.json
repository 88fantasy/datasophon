        "--with-http_v2_module",
        "--with-http_dav_module",
        "--with-http_slice_module",
        "--with-threads",
        "--with-http_addition_module",
        "--with-http_gunzip_module",
        "--with-http_gzip_static_module",
        "--with-http_sub_module",
        "--with-http_xslt_module=dynamic",
        "--with-stream=dynamic",
        "--with-stream_ssl_module",
        "--with-mail=dynamic",
        "--with-mail_ssl_module"
      ],
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": [
        "--http-log-path=/opt/datasophon/nginx-1.26.2/nginx/logs/access/access.log",
        "--error-log-path=/opt/datasophon/nginx-1.26.2/nginx/logs/error/error.log",
        "--lock-path=/opt/datasophon/nginx-1.26.2/nginx/sbin/nginx.lock",
        "--pid-path=/opt/datasophon/nginx-1.26.2/nginx/sbin/nginx.pid",
        "--http-client-body-temp-path=/opt/datasophon/nginx-1.26.2/nginx/temp/body",
        "--http-fastcgi-temp-path=/opt/datasophon/nginx-1.26.2/nginx/temp/fastcgi",
        "--http-proxy-temp-path=/opt/datasophon/nginx-1.26.2/nginx/temp/proxy",
        "--http-scgi-temp-path=/opt/datasophon/nginx-1.26.2/nginx/temp/scgi",
        "--http-uwsgi-temp-path=/opt/datasophon/nginx-1.26.2/nginx/temp/uwsgi",
        "--with-debug",
        "--with-pcre-jit",
        "--with-http_ssl_module",
        "--with-http_stub_status_module",
        "--with-http_realip_module",
        "--with-http_auth_request_module",
        "--with-http_v2_module",
        "--with-http_dav_module",
        "--with-http_slice_module",
        "--with-threads",
        "--with-http_addition_module",
        "--with-http_geoip_module",
        "--with-http_gunzip_module",
        "--with-http_gzip_static_module",
        "--with-http_image_filter_module=dynamic",
        "--with-http_sub_module",
        "--with-http_xslt_module=dynamic",
        "--with-stream=dynamic",
        "--with-stream_ssl_module",
        "--with-mail=dynamic",
        "--with-mail_ssl_module"
      ]
    },
    {
      "name": "nginxWorkerProcesses",
      "key": "nginxWorkerProcesses",
      "label": "nginx工作线程数",
      "description": "nginx工作线程数",
      "required": true,
      "type": "input",
      "configType": "map",
      "value": "4",
      "configurableInWizard": true,
      "hidden": false,
      "defaultValue": "4"
    },
    {
      "name": "nginxServerPort",
      "key": "nginxServerPort",
      "label": "nginx服务端口",
      "description": "nginx服务端口",
      "required": true,
