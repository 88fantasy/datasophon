{
  "name": "GRAFANA",
  "label": "Grafana",
  "description": "监控分析与数据可视化套件",
  "version": "9.5.21",
  "sortNum": 17,
  "type": "ENVIRONMENT",
  "dependencies": [],
  "packageName": "grafana-9.5.21.linux-amd64.tar.gz",
  "decompressPackageName": "grafana-v9.5.21",
  "arch": {
    "x86_64": {
      "packageName": "grafana-9.5.21.linux-amd64.tar.gz"
    },
    "aarch64": {
      "packageName": "grafana-9.5.21.linux-arm64.tar.gz"
    }
  },
  "roles": [
    {
      "name": "Grafana",
      "label": "Grafana",
      "roleType": "master",
      "runAs": {
        "user": "root",
        "group": "root"
      },
      "cardinality": 1,
      "logFile": "data/log/grafana.log",
      "jmxPort": "3000",
      "resourceStrategies":[{
        "type": "download",
        "from": "script/control.sh",
        "to": "control.sh",
        "md5": "31179a30dd4d8c3314a25eb32ddc0c7f"
      },{
        "type": "download",
        "from": "data/grafana.db",
        "to": "data/grafana.db",
        "md5": "4841ba20b7940a44f85899d0083287cb"
      }],
      "startRunner": {
        "timeout": "60",
        "program": "control.sh",
        "args": [
          "start",
          "grafana"
        ]
      },
      "stopRunner": {
        "timeout": "60",
        "program": "control.sh",
        "args": [
          "stop",
          "grafana"
        ]
      },
      "statusRunner": {
        "timeout": "60",
        "program": "control.sh",
        "args": [
          "status",
          "grafana"
        ]
      },
      "restartRunner": {
        "timeout": "60",
        "program": "control.sh",
        "args": [
          "restart",
          "grafana"
        ]
      },
      "externalLink": {
        "name": "Grafana Ui",
        "label": "Grafana Ui",
        "url": "http://${host}:3000"
      }
    }
  ],
  "configWriter": {
    "generators": [{
       "filename": "custom.ini",
       "configFormat": "custom",
       "outputDirectory": "conf",
       "templateName": "grafana.ftl",
       "conditionalOnProperty": "datasophon.proxy-grafana.enable",
       "includeParams": [
          "clusterId"
       ]
    }]
  },
  "parameters": [
      {
        "name": "clusterId",
        "label": "集群ID",
        "description": "集群ID",
        "configType": "map",
        "required": true,
        "type": "input",
        "value": "${clusterId}",
        "configurableInWizard": false,
        "hidden": true,
        "defaultValue": "${clusterId}"
      }
    ]
}