<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.datasophon.dao.mapper.FrameServiceRoleMapper">


    <select id="getServiceName" resultType="java.lang.String">
        select tdfs.service_name
        from t_ddh_frame_service_role tdfsr
                 inner join t_ddh_frame_service tdfs on
            tdfs.id = tdfsr.service_id
                 INNER JOIN t_ddh_frame_info tdfi on tdfs.frame_id = tdfi.id
        where tdfsr.service_role_name = #{serviceRoleName}
          and tdfi.frame_code = #{frameCode}
    </select>
</mapper>