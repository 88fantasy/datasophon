[
  {
    "title": "Max Uptime",
    "promql": [
      "max(max_over_time(redis_uptime_in_seconds{instance=~\"$instance\"}[$__interval]))"
    ],
    "unit": "s",
    "chartType": "stat",
    "thresholds": [
      {
        "color": "green",
        "value": null
      },
      {
        "color": "red",
        "value": 80
      }
    ],
    "legend": null
  },
  {
