  {
    "title": "Memory Usage",
    "promql": [
      "sum(100 * (redis_memory_used_bytes{instance=~\"$instance\"}  / redis_memory_max_bytes{instance=~\"$instance\"}))"
    ],
    "unit": "percent",
    "chartType": "gauge",
    "thresholds": [
      {
        "color": "rgba(50, 172, 45, 0.97)",
        "value": null
