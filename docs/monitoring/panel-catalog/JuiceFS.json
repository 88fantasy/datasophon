  {
    "title": "Uptime",
    "promql": [
      "sort(max(juicefs_uptime{vol_name=\"$name\"}) by (instance, juicefs_version))"
    ],
    "unit": "s",
    "chartType": "table",
    "thresholds": [
      {
        "color": "green",
        "value": null
      },
      {
        "color": "red",
        "value": 80
      }
    ],
    "legend": null
  },
