<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.0.0 http://maven.apache.org/xsd/assembly-2.0.0.xsd">

    <id>package</id>
    <formats>
        <format>tar.gz</format>
    </formats>
    <includeBaseDirectory>true</includeBaseDirectory>

    <fileSets>
        <!-- api 解包目录原样放入（不指定 fileMode，保留解包时的原始权限） -->
        <fileSet>
            <directory>${project.build.directory}/unpack/datasophon-manager-${project.version}</directory>
            <outputDirectory>datasophon-manager-${project.version}</outputDirectory>
            <directoryMode>0755</directoryMode>
        </fileSet>

        <!-- worker 解包目录原样放入（不指定 fileMode，保留解包时的原始权限） -->
        <fileSet>
            <directory>${project.build.directory}/unpack/datasophon-worker</directory>
            <outputDirectory>datasophon-worker</outputDirectory>
            <directoryMode>0755</directoryMode>
        </fileSet>

        <!-- CLI 二进制（linux-amd64） -->
        <fileSet>
            <directory>${basedir}/../datasophon-cli-go/target/dist</directory>
            <includes>
                <include>datasophon-cli-linux-amd64</include>
            </includes>
            <outputDirectory>datasophon-cli/bin</outputDirectory>
            <fileMode>0755</fileMode>
        </fileSet>

        <!-- CLI 二进制（linux-arm64） -->
        <fileSet>
            <directory>${basedir}/../datasophon-cli-go/target/dist</directory>
            <includes>
                <include>datasophon-cli-linux-arm64</include>
            </includes>
            <outputDirectory>datasophon-cli/bin</outputDirectory>
            <fileMode>0755</fileMode>
        </fileSet>

        <!-- CLI 集群配置样例 -->
        <fileSet>
            <directory>${basedir}/../datasophon-cli-go/configs</directory>
            <includes>
                <include>cluster-sample.yml</include>
            </includes>
            <outputDirectory>datasophon-cli/config</outputDirectory>
            <fileMode>0644</fileMode>
        </fileSet>

        <!-- CLI README -->
        <fileSet>
            <directory>${basedir}/../datasophon-cli-go</directory>
            <includes>
                <include>README.md</include>
            </includes>
            <outputDirectory>datasophon-cli</outputDirectory>
            <fileMode>0644</fileMode>
        </fileSet>

        <!-- CLI release.txt -->
        <fileSet>
            <directory>${basedir}/../datasophon-cli-go/target</directory>
            <includes>
                <include>release.txt</include>
            </includes>
            <outputDirectory>datasophon-cli</outputDirectory>
            <fileMode>0644</fileMode>
        </fileSet>
    </fileSets>
</assembly>
