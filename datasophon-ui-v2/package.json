{
  "name": "datasophon-ui",
  "version": "6.0.2",
  "private": true,
  "description": "DataSophon - Big Data Cluster Automation & Operations Platform",
  "scripts": {
    "analyze": "cross-env ANALYZE=1 max build",
    "build": "max build",
    "dev": "cross-env UMI_ENV=dev MOCK=none max dev",
    "lint": "npm run biome:lint && npm run tsc",
    "lint-staged": "lint-staged",
    "biome:lint": "biome lint",
    "biome": "biome check --write",
    "prepare": "npx husky && max setup",
    "preview": "max preview --port 8000",
    "preview:build": "max build && max preview --port 8000",
    "start": "cross-env UMI_ENV=dev max dev",
    "start:no-mock": "cross-env MOCK=none max dev",
    "start:pre": "cross-env UMI_ENV=pre MOCK=none max dev",
    "start:test": "cross-env UMI_ENV=test MOCK=none max dev",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "doctor": "react-doctor .",
    "tsc": "tsc --noEmit"
  },
  "browserslist": [
    "defaults"
  ],
  "dependencies": {
    "@ant-design/icons": "^6.2.3",
    "@ant-design/plots": "^2.6.8",
    "@ant-design/pro-components": "^3.1.12-0",
    "@ant-design/x": "^2.7.0",
    "@ant-design/x-markdown": "^2.7.0",
    "@ant-design/x-sdk": "^2.7.0",
    "@antv/x6": "^3.1.7",
    "@antv/x6-react-shape": "^3.0.1",
    "@monaco-editor/react": "^4.7.0",
    "@rc-component/util": "^1.11.0",
    "@tanstack/react-query": "^5.101.0",
    "antd": "^6.4.3",
    "antd-style": "^4.1.0",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "dayjs": "^1.11.20",
    "highlight.js": "^11.11.1",
    "insert-css": "^2.0.0",
    "js-yaml": "^4.2.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-simple-code-editor": "^0.14.1",
    "spark-md5": "^3.0.2",
    "topojson-client": "^3.1.0"
  },
  "devDependencies": {
    "@ant-design/cli": "^6.4.3",
    "@biomejs/biome": "^2.4.16",
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3": "^7.4.3",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-helmet": "^6.1.11",
    "@types/spark-md5": "^3.0.5",
    "@types/topojson-client": "^3.1.5",
    "@types/topojson-specification": "^1.0.5",
    "@umijs/lint": "^4.6.51",
    "@umijs/max": "^4.6.57",
    "@vitest/coverage-v8": "4.1.8",
    "@vitest/ui": "4.1.8",
    "cross-env": "^10.1.0",
    "express": "^5.2.1",
    "geojson": "^0.5.0",
    "happy-dom": "^20.10.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.2",
    "mockjs": "^1.1.0",
    "react-doctor": "^0.3.0",
    "swagger-ui-dist": "^5.32.5",
    "tailwindcss": "^4.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vite": "^7.3.5",
    "vitest": "4.1.8"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
